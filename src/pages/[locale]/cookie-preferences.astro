---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { supportedLocales, type Locale, getLocale } from '@/i18n/config';
import { loadMessages, t } from '@/i18n';
import { toHref } from '@/utils/navigationData';

export async function getStaticPaths() {
  return supportedLocales.map((locale) => ({
    params: { locale },
  }));
}

interface Props {
  locale: Locale;
}

const params = Astro.params as { locale?: string };
const locale: Locale = getLocale(params.locale);
const messages = await loadMessages(locale);
---

<BaseLayout title={t(messages, 'cookie.title')} messages={messages} locale={locale}>
  <div class="container mx-auto px-4 py-12 max-w-4xl">
    <h1 class="text-4xl font-bold text-gray-900 mb-6">{t(messages, 'cookie.title')}</h1>

    <p class="text-gray-700 mb-6 leading-relaxed">
      {t(messages, 'cookie.intro')}
    </p>
    <p class="text-gray-600 text-sm mb-10">
      {t(messages, 'cookie.whatAre')}
    </p>

    <div
      id="cookie-preferences"
      class="space-y-6"
      data-saved-msg={t(messages, 'cookie.saved')}
    >
      <!-- 必要 Cookie：不可关闭 -->
      <section class="rounded-xl border border-gray-200 bg-gray-50 p-5">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div class="flex-1 min-w-0">
            <h2 class="text-lg font-semibold text-gray-900 mb-1">{t(messages, 'cookie.necessary')}</h2>
            <p class="text-sm text-gray-600">{t(messages, 'cookie.necessaryDesc')}</p>
          </div>
          <span class="shrink-0 text-sm font-medium text-gray-500 bg-gray-200 px-3 py-1.5 rounded-lg">
            {t(messages, 'cookie.necessaryAlwaysOn')}
          </span>
        </div>
      </section>

      <!-- 分析 Cookie -->
      <section class="rounded-xl border border-gray-200 bg-white p-5">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div class="flex-1 min-w-0">
            <h2 class="text-lg font-semibold text-gray-900 mb-1">{t(messages, 'cookie.analytics')}</h2>
            <p class="text-sm text-gray-600">{t(messages, 'cookie.analyticsDesc')}</p>
          </div>
          <label class="shrink-0 flex items-center gap-2 cursor-pointer">
            <input type="checkbox" id="cookie-analytics" name="analytics" class="rounded border-gray-300 text-orange-500 focus:ring-orange-500" />
            <span class="text-sm font-medium text-gray-700 sr-only">{t(messages, 'cookie.analytics')}</span>
          </label>
        </div>
      </section>

      <!-- 功能 Cookie -->
      <section class="rounded-xl border border-gray-200 bg-white p-5">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div class="flex-1 min-w-0">
            <h2 class="text-lg font-semibold text-gray-900 mb-1">{t(messages, 'cookie.functional')}</h2>
            <p class="text-sm text-gray-600">{t(messages, 'cookie.functionalDesc')}</p>
          </div>
          <label class="shrink-0 flex items-center gap-2 cursor-pointer">
            <input type="checkbox" id="cookie-functional" name="functional" class="rounded border-gray-300 text-orange-500 focus:ring-orange-500" />
            <span class="text-sm font-medium text-gray-700 sr-only">{t(messages, 'cookie.functional')}</span>
          </label>
        </div>
      </section>

      <!-- 营销 Cookie -->
      <section class="rounded-xl border border-gray-200 bg-white p-5">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div class="flex-1 min-w-0">
            <h2 class="text-lg font-semibold text-gray-900 mb-1">{t(messages, 'cookie.marketing')}</h2>
            <p class="text-sm text-gray-600">{t(messages, 'cookie.marketingDesc')}</p>
          </div>
          <label class="shrink-0 flex items-center gap-2 cursor-pointer">
            <input type="checkbox" id="cookie-marketing" name="marketing" class="rounded border-gray-300 text-orange-500 focus:ring-orange-500" />
            <span class="text-sm font-medium text-gray-700 sr-only">{t(messages, 'cookie.marketing')}</span>
          </label>
        </div>
      </section>

      <div class="flex flex-wrap items-center gap-4 pt-4">
        <button
          type="button"
          id="cookie-save"
          class="px-6 py-2.5 bg-orange-500 text-white font-semibold rounded-lg hover:bg-orange-600 transition-colors"
        >
          {t(messages, 'cookie.save')}
        </button>
        <p id="cookie-saved-msg" class="text-green-600 font-medium text-sm hidden" role="status" aria-live="polite"></p>
      </div>
    </div>

    <p class="mt-10 pt-6 border-t border-gray-200">
      <a href={toHref('/privacy-policy', locale)} class="text-orange-600 hover:text-orange-700 font-medium">
        {t(messages, 'cookie.backToPrivacy')}
      </a>
    </p>
  </div>
</BaseLayout>

<script>
  (function () {
    const STORAGE_KEY = 'gloris-cookie-prefs';
    const container = document.getElementById('cookie-preferences');
    const saveBtn = document.getElementById('cookie-save');
    const savedMsg = document.getElementById('cookie-saved-msg');
    if (!container || !saveBtn || !savedMsg) return;

    const getPrefs = () => {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (raw) {
          const p = JSON.parse(raw);
          return { analytics: !!p.analytics, functional: !!p.functional, marketing: !!p.marketing };
        }
      } catch (_) {}
      return { analytics: true, functional: true, marketing: false };
    };

    const setPrefs = (prefs: { analytics: boolean; functional: boolean; marketing: boolean }) => {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(prefs));
    };

    const applyToPage = () => {
      const p = getPrefs();
      const a = document.getElementById('cookie-analytics') as HTMLInputElement | null;
      const f = document.getElementById('cookie-functional') as HTMLInputElement | null;
      const m = document.getElementById('cookie-marketing') as HTMLInputElement | null;
      if (a) a.checked = p.analytics;
      if (f) f.checked = p.functional;
      if (m) m.checked = p.marketing;
    };

    saveBtn.addEventListener('click', () => {
      const a = document.getElementById('cookie-analytics') as HTMLInputElement | null;
      const f = document.getElementById('cookie-functional') as HTMLInputElement | null;
      const m = document.getElementById('cookie-marketing') as HTMLInputElement | null;
      const analytics = a?.checked ?? true;
      const functional = f?.checked ?? true;
      const marketing = m?.checked ?? false;
      setPrefs({ analytics, functional, marketing });
      savedMsg.textContent = container.getAttribute('data-saved-msg') || 'Saved.';
      savedMsg.classList.remove('hidden');
      setTimeout(() => savedMsg.classList.add('hidden'), 3000);
    });

    applyToPage();
  })();
</script>
