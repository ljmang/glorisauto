---
/**
 * 帮助中心分类页：显示指定分类下的所有文章
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { type Locale, getLocale } from '@/i18n/config';
import { loadMessages, t } from '@/i18n';
import { fetchApi, api } from '@/utils/strapiApi';
import { toHref } from '@/utils/navigationData';
import { getHelpCategoryStaticPaths } from '@/utils/helpStaticPaths';
import Breadcrumb from '@/components/Breadcrumb.astro';
import type { HelpCategoryAttributes, HelpCenterAttributes } from '@/types/content';

export async function getStaticPaths() {
  return getHelpCategoryStaticPaths();
}

const params = Astro.params as { locale?: string; category?: string };
const locale: Locale = getLocale(params.locale);
const categorySlug = params.category ?? '';
const messages = await loadMessages(locale);

// 1. 获取所有分类（用于分类标签）
const categoriesRes = await fetchApi<{ data?: HelpCategoryAttributes[] }>(api.helpCategories, {
  locale,
  pagination: { pageSize: 100 },
});
const categories = (categoriesRes?.data ?? []).sort((a, b) => (a.sort ?? 0) - (b.sort ?? 0));

const allArticlesRes = await fetchApi<{ data?: HelpCenterAttributes[] }>(api.helpCenters, {
  locale,
  populate: { help_category: true },
  pagination: { pageSize: 500 },
});
const allArticles = allArticlesRes?.data ?? [];
const activeCategorySlugs = new Set(
  allArticles.map((article) => article.help_category?.slug).filter((slug): slug is string => Boolean(slug))
);
const activeCategories = categories.filter((category) => {
  const slug = category.slug ?? '';
  return slug !== '' && activeCategorySlugs.has(slug);
});

// 2. 获取当前分类信息
const currentCategoryRes = await fetchApi<{ data?: HelpCategoryAttributes[] }>(api.helpCategories, {
  locale,
  populate: {
    seo: {
      populate: {
        metaImage: true,
        ogImage: true,
        twitterImage: true,
      },
    },
  },
  filters: { slug: { $eq: categorySlug } },
});
const currentCategory = currentCategoryRes?.data?.[0];

if (!currentCategory) {
  const legacyCategoryRedirects: Record<string, string> = {
    'product-support': 'selection-guide',
    'sanding-polishing': 'application-process',
    'warranty-repair-service': 'troubleshooting-care',
  };
  const redirectSlug = legacyCategoryRedirects[categorySlug];
  if (redirectSlug) {
    return Astro.redirect(toHref(`/help/${redirectSlug}`, locale), 301);
  }
  return Astro.redirect(toHref('/help', locale), 301);
}

// 3. 获取该分类下的所有文章
const articlesRes = await fetchApi<{ data?: HelpCenterAttributes[] }>(api.helpCenters, {
  locale,
  populate: { help_category: true },
  filters: { help_category: { slug: { $eq: categorySlug } } },
  pagination: { pageSize: 500 },
});
const articles = (articlesRes?.data ?? []).sort((a, b) => (a.sort ?? 0) - (b.sort ?? 0));

const categoryName = currentCategory?.name ?? categorySlug;
const breadcrumbItems = [
  { label: t(messages, 'pageTitle.home'), href: '/' },
  { label: t(messages, 'footer.support.helpCenter'), href: '/help' },
  { label: categoryName },
];
const pageTitle = `${categoryName} - ${t(messages, 'footer.support.helpCenter')}`;
---

<BaseLayout
  title={pageTitle}
  description={currentCategory.description}
  seo={currentCategory.seo}
  pageType="collection"
  breadcrumbs={breadcrumbItems}
  messages={messages}
  locale={locale}
>
  <div class="container mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} locale={locale} />

    <h1 class="text-4xl lg:text-5xl font-black mb-8">{categoryName}</h1>

    <!-- 搜索框 -->
    <div class="mb-8">
      <div class="relative max-w-2xl">
        <input
          type="text"
          placeholder={t(messages, 'search.placeholder') || 'Search...'}
          class="w-full px-4 py-3 pl-12 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent"
        />
        <svg
          class="absolute left-4 top-1/2 transform -translate-y-1/2 w-5 h-5 text-gray-400"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
    </div>

    <!-- 分类标签 -->
    <div class="mb-8 flex flex-wrap gap-2 pb-4">
      <a
        href={toHref('/help', locale)}
        class="px-4 py-2 text-sm font-medium hover:text-orange-500 transition-colors"
      >
        {t(messages, 'common.all')}
      </a>
      {activeCategories.map((cat) => {
        const isActive = cat.slug === categorySlug;
        return (
          <a
            href={toHref(`/help/${cat.slug}`, locale)}
            class={`px-4 py-2 text-sm font-medium transition-colors ${
              isActive
                ? 'text-orange-500 border-b-2 border-orange-500'
                : 'hover:text-orange-500'
            }`}
          >
            {cat.name}
          </a>
        );
      })}
    </div>

    <!-- 文章列表 -->
    {articles.length > 0 ? (
      <div class="space-y-6">
        {articles.map((article) => {
          const articleHref = toHref(`/help/${categorySlug}/${article.slug}`, locale);
          return (
            <article class="border-b border-gray-200 pb-6 last:border-b-0">
              <h2 class="text-xl font-semibold mb-2">
                <a href={articleHref} class="text-cyan-600 hover:text-orange-500 hover:underline transition-colors">
                  {article.title}
                </a>
              </h2>
              {article.description && (
                <p class="text-gray-600 mb-2">{article.description}</p>
              )}
            </article>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-12">
        <p class="text-gray-500">{t(messages, 'helpCenter.noArticles')}</p>
      </div>
    )}
  </div>
</BaseLayout>
