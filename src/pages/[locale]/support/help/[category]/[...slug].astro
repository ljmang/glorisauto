---
import { getLocale, supportedLocales, type Locale } from '@/i18n/config';
import { fetchApi, api } from '@/utils/strapiApi';
import { toHref } from '@/utils/navigationData';
import type { HelpCenterAttributes } from '@/types/content';

export async function getStaticPaths() {
  const paths: { params: { locale: string; category: string; slug: string } }[] = [];
  for (const locale of supportedLocales) {
    const res = await fetchApi<{ data?: HelpCenterAttributes[] }>(api.helpCenters, {
      locale,
      populate: { help_category: true },
      pagination: { pageSize: 500 },
    });
    const articles = Array.isArray(res?.data) ? res.data : [];
    for (const article of articles) {
      const categorySlug = article.help_category?.slug;
      if (categorySlug && article.slug) {
        paths.push({
          params: {
            locale,
            category: categorySlug,
            slug: article.slug,
          },
        });
      }
    }
  }
  return paths;
}

const params = Astro.params as { locale?: string; category?: string; slug?: string };
const locale: Locale = getLocale(params.locale);
const category = params.category ?? '';
const slug = params.slug ?? '';

if (!category || !slug) {
  return Astro.redirect(toHref('/help', locale), 301);
}

return Astro.redirect(toHref(`/help/${category}/${slug}`, locale), 301);
---
