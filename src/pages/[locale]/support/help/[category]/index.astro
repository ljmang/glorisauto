---
import { getLocale, supportedLocales, type Locale } from '@/i18n/config';
import { fetchApi, api } from '@/utils/strapiApi';
import { toHref } from '@/utils/navigationData';
import type { HelpCategoryAttributes } from '@/types/content';

export async function getStaticPaths() {
  const paths: { params: { locale: string; category: string } }[] = [];
  for (const locale of supportedLocales) {
    const res = await fetchApi<{ data?: HelpCategoryAttributes[] }>(api.helpCategories, {
      locale,
      pagination: { pageSize: 100 },
    });
    const categories = Array.isArray(res?.data) ? res.data : [];
    for (const category of categories) {
      if (category.slug) {
        paths.push({ params: { locale, category: category.slug } });
      }
    }
  }
  return paths;
}

const params = Astro.params as { locale?: string; category?: string };
const locale: Locale = getLocale(params.locale);
const category = params.category ?? '';

if (!category) {
  return Astro.redirect(toHref('/help', locale), 301);
}

return Astro.redirect(toHref(`/help/${category}`, locale), 301);
---
