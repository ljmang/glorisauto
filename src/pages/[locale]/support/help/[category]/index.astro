---
import { getLocale, type Locale } from '@/i18n/config';
import { getHelpCategoryStaticPaths } from '@/utils/helpStaticPaths';
import { toHref } from '@/utils/navigationData';

export async function getStaticPaths() {
  return getHelpCategoryStaticPaths();
}

const params = Astro.params as { locale?: string; category?: string };
const locale: Locale = getLocale(params.locale);
const category = params.category ?? '';

if (!category) {
  return Astro.redirect(toHref('/help', locale), 301);
}

return Astro.redirect(toHref(`/help/${category}`, locale), 301);
---
