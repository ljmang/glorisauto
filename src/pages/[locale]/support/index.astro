---
/**
 * Support 首页：面包屑 + 大标题 + 三张卡片，数据来自 Strapi Support 单类型的 module，复用 InsightCard
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { supportedLocales, type Locale, getLocale } from '@/i18n/config';
import { loadMessages, t } from '@/i18n';
import { fetchApiWithLocaleFallback, api } from '@/utils/strapiApi';
import { toHref } from '@/utils/navigationData';
import Breadcrumb from '@/components/Breadcrumb.astro';
import InsightCard from '@/components/InsightCard.astro';
import type { InsightAttributes, SupportAttributes } from '@/types/content';

export async function getStaticPaths() {
  return supportedLocales.map((locale: Locale) => ({
    params: { locale },
  }));
}

const params = Astro.params as { locale?: string };
const locale: Locale = getLocale(params.locale);
const messages = await loadMessages(locale);

const supportRes = await fetchApiWithLocaleFallback<{ data: SupportAttributes | null }>(api.support, {
  locale,
  populate: {
    module: { populate: { cover: true } },
    seo: {
      populate: {
        metaImage: true,
        ogImage: true,
        twitterImage: true,
      },
    },
  },
});
const rawModules = supportRes?.data?.module ?? [];
const supportCards = [...rawModules]
  .sort((a, b) => (a.sort ?? 0) - (b.sort ?? 0))
  .map((m) => {
    const normalizedUrl = (m.url ?? '').replace(/^\/support\/help(?=\/|$)/, '/help');
    return { ...m, url: normalizedUrl };
  })
  .map((m) => ({
    insight: {
      title: m.title ?? '',
      slug: m.slug ?? 'item',
      cover: m.cover ?? null,
    } as InsightAttributes & { cover?: unknown },
    path: m.url || `/support/${m.slug || 'item'}`,
  }));

const breadcrumbItems = [
  { label: t(messages, 'pageTitle.home'), href: '/' },
  { label: t(messages, 'footer.support.title') },
];
const pageTitle = supportRes?.data?.title ?? t(messages, 'footer.support.title');
---

<BaseLayout
  title={pageTitle}
  seo={supportRes?.data?.seo}
  pageType="collection"
  breadcrumbs={breadcrumbItems}
  messages={messages}
  locale={locale}
>
  <div class="container mx-auto px-4 py-12">
    <Breadcrumb items={breadcrumbItems} locale={locale} />

    <h1 class="text-4xl lg:text-5xl font-black mb-8">{pageTitle}</h1>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {supportCards.map(({ insight, path }) => (
        <div class="rounded-lg border border-gray-200 bg-white overflow-hidden shadow-sm hover:shadow-md transition-shadow h-full">
          <InsightCard insight={insight} locale={locale} href={toHref(path, locale)} />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
