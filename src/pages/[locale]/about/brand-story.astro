---
/**
 * 品牌故事页：从后端 brand-story 单类型获取标题、slug、markdown 内容并渲染
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { supportedLocales, type Locale, getLocale } from '@/i18n/config';
import { loadMessages, t } from '@/i18n';
import { fetchApiWithLocaleFallback, api } from '@/utils/strapiApi';
import { markdownToHtml } from '@/utils/markdown';
import type { StrapiResponse, StrapiSeo } from '@/types';

export async function getStaticPaths() {
  return supportedLocales.map((locale) => ({
    params: { locale },
  }));
}

interface Props {
  locale: Locale;
}

/** 后端 brand-story 单类型：Title（大写）、slug、content（markdown） */
interface BrandStoryData {
  Title?: string;
  slug?: string;
  content?: string;
  description?: string;
  seo?: StrapiSeo | null;
}

const params = Astro.params as { locale?: string };
const locale: Locale = getLocale(params.locale);
const messages = await loadMessages(locale);

const res = await fetchApiWithLocaleFallback<StrapiResponse<BrandStoryData>>(api.brandStory, {
  locale,
  populate: {
    seo: {
      populate: {
        metaImage: true,
        ogImage: true,
        twitterImage: true,
      },
    },
  },
});

const brandStory = res?.data;

// 与 insights [slug].astro 一致的 Astro markdown 处理（unified + remark/rehype）
const contentHtml = brandStory?.content ? await markdownToHtml(brandStory.content) : '';
const pageTitle = brandStory?.Title ?? t(messages, 'footer.about.brandStory');

const breadcrumbItems = [
  { label: t(messages, 'pageTitle.home'), href: '/' },
  { label: t(messages, 'pageTitle.about'), href: '/about' },
  { label: pageTitle, href: undefined },
];
---

<BaseLayout
  title={pageTitle}
  description={brandStory?.description}
  seo={brandStory?.seo}
  pageType="about"
  breadcrumbs={breadcrumbItems}
  messages={messages}
  locale={locale}
>
  <div class="container mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} locale={locale} />

    {brandStory && (
      <article class="max-w-4xl mx-auto py-8">
        {brandStory.Title && (
          <h1 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-8">
            {brandStory.Title}
          </h1>
        )}

        {contentHtml ? (
          <div
            class="prose prose-lg max-w-none text-gray-700 prose-headings:font-bold prose-img:rounded-lg prose-a:text-cyan-600 prose-a:no-underline hover:prose-a:text-orange-600"
            set:html={contentHtml}
          />
        ) : null}
      </article>
    )}
  </div>
</BaseLayout>
