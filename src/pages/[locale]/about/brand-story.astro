---
/**
 * 品牌故事页：从后端 brand-story 单类型获取标题、slug、markdown 内容并渲染
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { supportedLocales, type Locale, getLocale } from '@/i18n/config';
import { loadMessages, t } from '@/i18n';
import { fetchApiWithLocaleFallback, api } from '@/utils/strapiApi';
import { markdownToHtml } from '@/utils/markdown';
import type { StrapiResponse, StrapiSeo } from '@/types';

export async function getStaticPaths() {
  return supportedLocales.map((locale) => ({
    params: { locale },
  }));
}

interface Props {
  locale: Locale;
}

/** 后端 brand-story 单类型：Title（大写）、slug、content（markdown） */
interface BrandStoryData {
  Title?: string;
  slug?: string;
  content?: string;
  description?: string;
  seo?: StrapiSeo | null;
}

const params = Astro.params as { locale?: string };
const locale: Locale = getLocale(params.locale);
const messages = await loadMessages(locale);

const res = await fetchApiWithLocaleFallback<StrapiResponse<BrandStoryData>>(api.brandStory, {
  locale,
  populate: {
    seo: {
      populate: {
        metaImage: true,
        ogImage: true,
        twitterImage: true,
      },
    },
  },
});

const brandStory = res?.data;

const pageTitle = brandStory?.Title ?? t(messages, 'footer.about.brandStory');
const brandStoryDescription = brandStory?.description?.trim() ?? '';
// 与 insights [slug].astro 一致的 Astro markdown 处理（unified + remark/rehype）
const contentHtml = brandStory?.content ? await markdownToHtml(brandStory.content, pageTitle) : '';

const breadcrumbItems = [
  { label: t(messages, 'pageTitle.home'), href: '/' },
  { label: t(messages, 'pageTitle.about'), href: '/about' },
  { label: pageTitle, href: undefined },
];
---

<BaseLayout
  title={pageTitle}
  description={brandStory?.description}
  seo={brandStory?.seo}
  pageType="about"
  breadcrumbs={breadcrumbItems}
  messages={messages}
  locale={locale}
>
  <div class="container mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} locale={locale} />

    {brandStory && (
      <article class="mx-auto max-w-[820px] py-8">
        <header class="mb-10 border-b border-slate-200 pb-8">
          <span class="mb-4 inline-flex items-center rounded-full bg-orange-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-orange-600">
            {t(messages, 'pageTitle.about')}
          </span>
          {brandStory.Title && (
            <h1 class="mb-4 text-4xl font-black leading-tight text-slate-950 lg:text-5xl">
              {brandStory.Title}
            </h1>
          )}
          {brandStoryDescription && (
            <p class="max-w-[760px] text-xl leading-8 text-slate-600">
              {brandStoryDescription}
            </p>
          )}
        </header>

        {contentHtml ? (
          <div
            class="article-content prose prose-lg mb-16 max-w-none"
            set:html={contentHtml}
          />
        ) : null}
      </article>
    )}
  </div>
</BaseLayout>
