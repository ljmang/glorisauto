---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import InsightCard from '@/components/InsightCard.astro';
import { supportedLocales, type Locale, getLocale, isRtlLocale } from '@/i18n/config';
import { loadMessages, t } from '@/i18n';
import { fetchApiWithLocaleFallback, api, parseImage } from '@/utils/strapiApi';
import { toHref } from '@/utils/navigationData';
import { fetchSiteSeo } from '@/utils/siteConfig';
import { getSiteContactInfo } from '@/utils/siteContact';
import type { AboutUsAttributes, InsightAttributes } from '@/types/content';
import type { StrapiResponse } from '@/types';
import { Image } from 'astro:assets';
import { CircleChevronRight, Phone, Mail } from 'lucide-svelte';

const ABOUT_PAGE_ADDRESS_BY_LOCALE: Record<Locale, string> = {
  en: 'Fengheyuan Logistics Center, Baisha Road, Nanhai District, Foshan, Guangdong, China',
  'zh-cn': '中国广东省佛山市南海区白沙路丰禾园物流中心',
  ja: 'Fengheyuan Logistics Center, Baisha Road, Nanhai District, Foshan, Guangdong, China',
  ar: 'Fengheyuan Logistics Center, Baisha Road, Nanhai District, Foshan, Guangdong, China',
};

const ABOUT_PAGE_MAP_QUERY =
  'Fengheyuan Logistics Center, Baisha Road, Nanhai District, Foshan, Guangdong, China';
const ABOUT_PAGE_MAP_LINK_URL = `https://www.google.com/maps?q=${encodeURIComponent(ABOUT_PAGE_MAP_QUERY)}`;
const ABOUT_PAGE_MAP_EMBED_URL = `https://maps.google.com/maps?q=${encodeURIComponent(ABOUT_PAGE_MAP_QUERY)}&z=12&output=embed`;

export async function getStaticPaths() {
  return supportedLocales.map((locale) => ({
    params: { locale },
  }));
}

const params = Astro.params as { locale?: string };
const locale: Locale = getLocale(params.locale);
const isRtl = isRtlLocale(locale);
const messages = await loadMessages(locale);

const normalizeInsightsCount = (value: number | undefined, fallback: number) =>
  typeof value === 'number' && Number.isFinite(value) && value > 0
    ? Math.floor(value)
    : fallback;

const [aboutUsRes, siteSeo] = await Promise.all([
  fetchApiWithLocaleFallback<StrapiResponse<AboutUsAttributes>>(api.aboutUs, {
    locale,
    populate: {
      heroMedia: true,
      seo: {
        populate: {
          metaImage: true,
          ogImage: true,
          twitterImage: true,
        },
      },
      insights: { populate: { cover: true, insight_category: true } },
    },
  }),
  fetchSiteSeo(locale),
]);

// 处理 about-us 数据（单类型）
const aboutUs = aboutUsRes?.data;
const heroMedia = aboutUs ? parseImage(aboutUs.heroMedia) : null;
const featuredInsightsCount = normalizeInsightsCount(aboutUs?.insightsCount, 2);
const latestInsightsCount = normalizeInsightsCount(aboutUs?.latestInsightsCount, 3);

const latestInsightsRes = aboutUs
  ? await fetchApiWithLocaleFallback<{ data?: InsightAttributes[] }>(api.insights, {
      locale,
      populate: { cover: true, insight_category: true },
      sort: ['publishedAt:desc'],
      pagination: {
        pageSize: featuredInsightsCount + latestInsightsCount,
      },
    })
  : null;

const manualFeaturedArticles = Array.isArray(aboutUs?.insights)
  ? aboutUs.insights.filter((insight) => Boolean(insight?.slug))
  : [];
const allLatestInsights = Array.isArray(latestInsightsRes?.data)
  ? latestInsightsRes.data.filter((insight) => Boolean(insight?.slug))
  : [];
const featuredArticles = manualFeaturedArticles.slice(0, featuredInsightsCount);
const featuredInsightSlugs = new Set(
  featuredArticles.map((article) => article.slug).filter((slug): slug is string => Boolean(slug))
);
const latestInsights = allLatestInsights
  .filter((insight) => !featuredInsightSlugs.has(insight.slug))
  .slice(0, latestInsightsCount);
const storyLinkLabel = aboutUs?.storyLinkLabel?.trim() || t(messages, 'common.readMore');
const storyLinkHref = toHref(aboutUs?.storyLink?.trim() || '/about/insights/news/brand-story', locale);
const latestInsightsTitle = aboutUs?.latestInsightsTitle?.trim() || t(messages, 'footer.about.insights');
const latestInsightsLinkLabel =
  aboutUs?.latestInsightsLinkLabel?.trim() || t(messages, 'common.viewAll');
const latestInsightsLinkHref = toHref(aboutUs?.latestInsightsLink?.trim() || '/about/insights', locale);
const messageButtonHref = toHref(aboutUs?.messageButtonLink?.trim() || '/contact', locale);
const siteContact = getSiteContactInfo(siteSeo);
const phoneTitle = aboutUs?.phoneTitle?.trim() || t(messages, 'form.phone');
const addressTitle = siteContact.addressTitle || t(messages, 'contactInfo.address');
const mapLinkLabel = siteContact.mapLinkLabel || t(messages, 'contactInfo.mapLink');
const mapEmbedTitle = siteContact.mapEmbedTitle || 'Gloris location map';
const aboutPageContact = {
  ...siteContact,
  address: ABOUT_PAGE_ADDRESS_BY_LOCALE[locale],
  mapLinkUrl: ABOUT_PAGE_MAP_LINK_URL,
  mapEmbedUrl: ABOUT_PAGE_MAP_EMBED_URL,
};

const breadcrumbItems = [
  { label: t(messages, 'pageTitle.home'), href: '/' },
  { label: t(messages, 'pageTitle.about'), href: undefined },
];

---

<BaseLayout
  title={t(messages, 'pageTitle.about')}
  description={aboutUs?.description}
  image={aboutUs?.heroMedia}
  seo={aboutUs?.seo}
  pageType="about"
  breadcrumbs={breadcrumbItems}
  messages={messages}
  locale={locale}
  siteSeo={siteSeo}
>
  {aboutUs && (
    <>
      <!-- 面包屑导航 -->
      <div class="container mx-auto px-4 pt-4 pb-2">
        <Breadcrumb items={breadcrumbItems} locale={locale} />
      </div>

      <!-- 1. 顶部：品牌故事介绍 - 全宽背景图，白色半透明框 -->
      {heroMedia && heroMedia.src && (
        <section class="relative container mx-auto px-4 min-h-[600px]">
          <Image
            src={heroMedia.src}
            alt={heroMedia.alt || aboutUs.title || t(messages, 'pageTitle.about')}
            width={heroMedia.width || 2720}
            height={heroMedia.height || 1120}
            class="w-full h-full object-cover absolute inset-0"
            format="webp"
            quality={100}
            loading="eager"
          />
          <!-- 白色半透明内容框 -->
          <div class={`absolute bottom-0 left-0 right-0 lg:w-[640px] bg-white/95 p-8 lg:p-12 ${isRtl ? 'lg:right-8 lg:left-auto' : 'lg:left-8 lg:right-auto'}`}>
            {aboutUs.title && (
              <h1 class="text-3xl lg:text-4xl font-bold  mb-3">
                {aboutUs.title}
              </h1>
            )}
            {aboutUs.subTitle && (
              <h2 class="text-xl lg:text-2xl font-semibold  mb-4">
                {aboutUs.subTitle}
              </h2>
            )}
            {aboutUs.description && (
              <p class="text-base lg:text-lg  mb-6 leading-relaxed">
                {aboutUs.description}
              </p>
            )}
            <a
              href={storyLinkHref}
              class="inline-flex items-center gap-2 text-cyan-600 hover:text-orange-600 transition-colors font-semibold"
            >
              {storyLinkLabel}
              <CircleChevronRight class="w-4 h-4" />
            </a>
          </div>
        </section>
      )}

      <div class="container mx-auto px-4 py-12 lg:py-16">
        <!-- 2. 中间：后台手动指定文章 -->
        {featuredArticles.length > 0 && (
          <section class="mb-16 lg:mb-20 space-y-16 lg:space-y-20">
            {featuredArticles.map((article, index) => {
              const coverImage = parseImage(article.cover || (article as { coverImage?: unknown }).coverImage);
              const isEven = index % 2 === 0;
              const category = article.insight_category && typeof article.insight_category === 'object' && 'slug' in article.insight_category
                ? article.insight_category
                : null;
              const categorySlug = category?.slug ?? '';
              const href = categorySlug && article.slug
                ? toHref(`/about/insights/${categorySlug}/${article.slug}`, locale)
                : toHref(`/about/insights/${article.slug}`, locale);

              return (
                <div class={`grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center ${!isEven ? 'lg:flex-row-reverse' : ''}`}>
                  <!-- 图片 -->
                  {coverImage && coverImage.src && coverImage.width && coverImage.height ? (
                    <div class={isEven ? 'order-1' : 'order-2'}>
                      <Image
                        src={coverImage.src}
                        alt={coverImage.alt || article.title}
                        width={coverImage.width}
                        height={coverImage.height}
                        class="w-full h-auto object-cover"
                        format="webp"
                        quality={100}
                        loading="lazy"
                      />
                    </div>
                  ) : null}
                  
                  <!-- 内容 -->
                  <div class={isEven ? 'order-2' : 'order-1'}>
                    <h3 class="text-2xl lg:text-3xl font-bold  mb-4">
                      {article.title}
                    </h3>
                    {(article.description || article.excerpt) && (
                      <p class="text-base lg:text-lg  mb-6 leading-relaxed">
                        {article.description || article.excerpt}
                      </p>
                    )}
                    <a
                      href={href}
                      class="inline-flex items-center gap-2 text-cyan-600 hover:text-orange-600 transition-colors font-semibold"
                    >
                      {t(messages, 'common.readMore')}
                      <CircleChevronRight class="w-4 h-4" />
                    </a>
                  </div>
                </div>
              );
            })}
          </section>
        )}

        <!-- 3. 联系我们 -->
        {aboutUs.contactGlorisTitle && (
          <section class="mb-16 lg:mb-20">
            <h2 class="text-3xl lg:text-4xl font-bold  mb-8">
              {aboutUs.contactGlorisTitle}
            </h2>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
              <!-- 左侧：联系信息 -->
              <div class="space-y-6">
                {aboutUs.messageTitle && (
                  <div>
                    <h3 class="text-xl font-bold  mb-2">
                      {aboutUs.messageTitle}
                    </h3>
                    {aboutUs.messageDescription && (
                      <p class=" mb-3">
                        {aboutUs.messageDescription}
                      </p>
                    )}
                    <a
                      href={messageButtonHref}
                      class="inline-flex items-center gap-2 text-cyan-600 hover:text-orange-600 transition-colors font-semibold"
                    >
                      {aboutUs.messageButton || t(messages, 'common.readMore')}
                      <CircleChevronRight class="w-4 h-4" />
                    </a>
                  </div>
                )}

                {(aboutUs.phoneTitle || siteContact.phone || siteContact.email) && (
                  <div>
                    <h3 class="text-xl font-bold  mb-2">
                      {phoneTitle}
                    </h3>
                    {aboutUs.phoneDescription && (
                      <p class=" mb-1">
                        {aboutUs.phoneDescription}
                      </p>
                    )}
                    {siteContact.phone && (
                      <p class=" mb-1">
                        <a href={siteContact.phoneHref} class="hover:text-orange-600 flex items-center gap-2">
                          <Phone class="w-4 h-4" />
                          {siteContact.phone}
                        </a>
                      </p>
                    )}
                    {siteContact.email && (
                      <p class="">
                        <a href={`mailto:${siteContact.email}`} class="hover:text-orange-600 flex items-center gap-2">
                          <Mail class="w-4 h-4" />
                          {siteContact.email}
                        </a>
                      </p>
                    )}
                  </div>
                )}

                {aboutPageContact.address && (
                  <div>
                    <h3 class="text-xl font-bold  mb-2">
                      {addressTitle}
                    </h3>
                    <p class="">
                      {aboutPageContact.address}
                    </p>
                    <a
                      href={aboutPageContact.mapLinkUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-block mt-3 text-cyan-600 hover:text-orange-600 transition-colors"
                    >
                      {mapLinkLabel}
                    </a>
                  </div>
                )}
              </div>

              <!-- 右侧：Google 地图（默认广州） -->
              <div class="w-full h-[400px] rounded-lg overflow-hidden bg-gray-200">
                <iframe
                  src={aboutPageContact.mapEmbedUrl}
                  width="100%"
                  height="100%"
                  style="border:0;"
                  allowfullscreen
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title={mapEmbedTitle}
                ></iframe>
              </div>
            </div>
          </section>
        )}

        <!-- 4. 最新文章 -->
        {latestInsights.length > 0 && (
          <section class="mt-16 pt-16 border-t border-gray-200">
            <div class="flex items-center justify-between mb-8">
              <h2 class="text-3xl lg:text-4xl font-bold ">
                {latestInsightsTitle}
              </h2>
              <a
                href={latestInsightsLinkHref}
                class="text-cyan-600 text-lg flex items-center gap-2 hover:text-orange-600 transition-colors"
              >
                {latestInsightsLinkLabel}
                <CircleChevronRight class="w-4 h-4" />
              </a>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
              {latestInsights.map((insight) => (
                <InsightCard insight={insight} locale={locale} />
              ))}
            </div>
          </section>
        )}
      </div>
    </>
  )}
</BaseLayout>
