---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import InsightListItem from '@/components/InsightListItem.astro';
import { supportedLocales, type Locale, getLocale } from '@/i18n/config';
import { loadMessages, t } from '@/i18n';
import { fetchApiWithLocaleFallback, api } from '@/utils/strapiApi';
import { toHref } from '@/utils/navigationData';
import { resolveCollectionPageCopy } from '@/utils/collectionPageCopy';
import { fetchSiteSeo } from '@/utils/siteConfig';
import type { InsightAttributes, InsightCategoryAttributes } from '@/types/content';

export async function getStaticPaths() {
  return supportedLocales.map((locale) => ({
    params: { locale },
  }));
}

interface Props {
  locale: Locale;
}

const params = Astro.params as { locale?: string };
const locale: Locale = getLocale(params.locale);
const messages = await loadMessages(locale);

const [categoriesRes, insightsRes, siteSeo] = await Promise.all([
  fetchApiWithLocaleFallback<{ data?: InsightCategoryAttributes[] }>(api.insightCategories, {
    locale,
    pagination: { pageSize: 100 },
  }),
  fetchApiWithLocaleFallback<{ data?: InsightAttributes[] }>(api.insights, {
    locale,
    populate: { cover: true, insight_category: true },
    pagination: { pageSize: 100 },
  }),
  fetchSiteSeo(locale),
]);

const categories = (Array.isArray(categoriesRes?.data) ? categoriesRes.data : [])
  .filter((c) => c?.name != null)
  .sort((a, b) => (a.sort ?? 0) - (b.sort ?? 0));
const insights = (Array.isArray(insightsRes?.data) ? insightsRes.data : [])
  .sort((a, b) => {
    const dateA = a.publishedAt ? new Date(a.publishedAt).getTime() : 0;
    const dateB = b.publishedAt ? new Date(b.publishedAt).getTime() : 0;
    return dateB - dateA; // 降序：最新的在前
  });

const breadcrumbItems = [
  { label: t(messages, 'pageTitle.home'), href: '/' },
  { label: t(messages, 'footer.about.insights'), href: undefined },
];
const pageTitle = t(messages, 'footer.about.insights');
const allArticlesLabel = t(messages, 'insights.allArticles');
const pageCopy = resolveCollectionPageCopy(locale, 'insights', siteSeo);
---

<BaseLayout
  title={pageCopy.seoTitle}
  description={pageCopy.seoDescription}
  pageType="collection"
  breadcrumbs={breadcrumbItems}
  messages={messages}
  locale={locale}
>
  <div class="container mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} locale={locale} />

    <div class="flex flex-col md:flex-row gap-4 md:gap-8">
      <!-- 左侧：分类导航 -->
      <aside class="md:w-56 shrink-0 font-bold md:sticky md:top-60 md:self-start hidden md:block">
        <nav class="space-y-1" aria-label={t(messages, 'insights.allArticles')}>
          <a
            href={toHref('/about/insights', locale)}
            class="block p-2 hover:bg-gray-100 hover:text-orange-500 transition-colors text-orange-500"
          >
            {allArticlesLabel}
          </a>
          {categories.map((cat) => (
            <a
              href={toHref(`/about/insights/${cat.slug}`, locale)}
              class="block p-2 hover:bg-gray-100 hover:text-orange-500 transition-colors"
            >
              {cat.name}
            </a>
          ))}
        </nav>
      </aside>

      <!-- 右侧：文章列表 -->
      <main class="flex-1 min-w-0 mb-12">
        <h1 class="text-4xl lg:text-5xl font-black mb-4">{pageCopy.heading}</h1>
        <p class="max-w-4xl text-base leading-7 text-gray-600 mb-8 lg:text-lg lg:leading-8">
          {pageCopy.intro}
        </p>
        <div class="space-y-6">
          {insights.length > 0 ? (
            insights.map((insight) => <InsightListItem insight={insight} locale={locale} messages={messages} />)
          ) : (
            <p class="text-gray-500 py-12">{t(messages, 'search.noResults')}</p>
          )}
        </div>

        {insights.length > 0 && (
          <nav aria-label="Pagination" class="mt-12 flex justify-center items-center gap-2">
            <button type="button" class="px-3 py-2 text-gray-600 hover:text-orange-500 disabled:opacity-50 disabled:cursor-not-allowed transition-colors" disabled>&lt;</button>
            <a href={toHref('/about/insights', locale)} class="px-4 py-2 bg-cyan-600 text-white rounded hover:bg-cyan-700 transition-colors">1</a>
            <button type="button" class="px-3 py-2 text-gray-600 hover:text-orange-500 disabled:opacity-50 disabled:cursor-not-allowed transition-colors" disabled>&gt;</button>
          </nav>
        )}
      </main>
    </div>
  </div>
</BaseLayout>
