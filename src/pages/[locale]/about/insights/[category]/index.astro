---
/**
 * Insights 分类页：slug 为 insight-category 的 slug，左侧分类导航高亮当前项，右侧为该分类下的文章列表
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import InsightListItem from '@/components/InsightListItem.astro';
import { supportedLocales, type Locale, getLocale } from '@/i18n/config';
import { loadMessages, t } from '@/i18n';
import { fetchApiWithLocaleFallback, api } from '@/utils/strapiApi';
import { toHref } from '@/utils/navigationData';
import type { InsightAttributes, InsightCategoryAttributes } from '@/types/content';

export async function getStaticPaths() {
  const paths: { params: { locale: string; category: string } }[] = [];
  for (const locale of supportedLocales) {
    const res = await fetchApiWithLocaleFallback<{ data?: InsightCategoryAttributes[] }>(api.insightCategories, {
      locale,
      pagination: { pageSize: 100 },
    });
    const list = Array.isArray(res?.data) ? res.data : [];
    for (const cat of list) {
      if (cat.slug) paths.push({ params: { locale, category: cat.slug } });
    }
  }
  return paths;
}

const params = Astro.params as { locale?: string; category?: string };
const locale: Locale = getLocale(params.locale);
const categorySlug = params.category ?? '';
const messages = await loadMessages(locale);

// 所有分类（侧边栏）
const categoriesRes = await fetchApiWithLocaleFallback<{ data?: InsightCategoryAttributes[] }>(api.insightCategories, {
  locale,
  pagination: { pageSize: 100 },
});
const categories = (Array.isArray(categoriesRes?.data) ? categoriesRes.data : [])
  .filter((c) => c?.name != null)
  .sort((a, b) => (a.sort ?? 0) - (b.sort ?? 0));
const currentCategory = categories.find((c) => c.slug === categorySlug);
const categoryName = currentCategory?.name ?? categorySlug;

// 当前分类下的文章
const insightsRes = await fetchApiWithLocaleFallback<{ data?: InsightAttributes[] }>(api.insights, {
  locale,
  populate: { cover: true, insight_category: true },
  pagination: { pageSize: 100 },
  filters: {
    insight_category: {
      slug: { $eq: categorySlug },
    },
  },
});
const insights = (Array.isArray(insightsRes?.data) ? insightsRes.data : [])
  .sort((a, b) => {
    const dateA = a.publishedAt ? new Date(a.publishedAt).getTime() : 0;
    const dateB = b.publishedAt ? new Date(b.publishedAt).getTime() : 0;
    return dateB - dateA; // 降序：最新的在前
  });

const breadcrumbItems = [
  { label: t(messages, 'pageTitle.home'), href: '/' },
  { label: t(messages, 'footer.about.insights'), href: '/about/insights' },
  { label: categoryName, href: undefined },
];
const pageTitle = categoryName;
const allArticlesLabel = t(messages, 'insights.allArticles');
---

<BaseLayout
  title={`${categoryName} - ${t(messages, 'footer.about.insights')}`}
  messages={messages}
  locale={locale}
>
  <div class="container mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} locale={locale} />

    <div class="flex flex-col md:flex-row gap-4 md:gap-8">
      <!-- 左侧：分类导航，当前分类高亮 -->
      <aside class="md:w-56 shrink-0 font-bold md:sticky md:top-60 md:self-start hidden md:block">
        <nav class="space-y-1" aria-label={t(messages, 'insights.allArticles')}>
          <a
            href={toHref('/about/insights', locale)}
            class="block p-2 hover:bg-gray-100 hover:text-orange-500 transition-colors"
          >
            {allArticlesLabel}
          </a>
          {categories.map((cat) => {
            const isActive = cat.slug === categorySlug;
            return (
              <a
                href={toHref(`/about/insights/${cat.slug}`, locale)}
                class={`block p-2 hover:bg-gray-100 hover:text-orange-500 transition-colors ${isActive ? 'text-orange-500' : ''}`}
              >
                {cat.name}
              </a>
            );
          })}
        </nav>
      </aside>

      <!-- 右侧：文章列表 -->
      <main class="flex-1 min-w-0 mb-12">
        <h1 class="text-4xl lg:text-5xl font-black mb-6">{pageTitle}</h1>
        <div class="space-y-6">
          {insights.length > 0 ? (
            insights.map((insight) => <InsightListItem insight={insight} locale={locale} messages={messages} />)
          ) : (
            <p class="text-gray-500 py-12">{t(messages, 'search.noResults')}</p>
          )}
        </div>
      </main>
    </div>
  </div>
</BaseLayout>
