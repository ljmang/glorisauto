---
/**
 * Insights 文章详情页：标题、发布时间、简介、markdown 内容 + 相关产品、相关文章
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ProductCard from '@/components/ProductCard.astro';
import InsightCard from '@/components/InsightCard.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import ArticleSampleCta from '@/components/ArticleSampleCta.astro';
import { supportedLocales, type Locale, getLocale, localeDateTag } from '@/i18n/config';
import { loadMessages, t } from '@/i18n';
import { fetchApiWithLocaleFallback, api } from '@/utils/strapiApi';
import { toHref } from '@/utils/navigationData';
import type { InsightAttributes, InsightCategoryAttributes, ProductAttributes } from '@/types/content';
import { renderMarkdownWithTOC } from '@/utils/markdown';

export async function getStaticPaths() {
  const paths: { params: { locale: string; category: string; slug: string } }[] = [];
  for (const locale of supportedLocales) {
    const res = await fetchApiWithLocaleFallback<{ data?: InsightAttributes[] }>(api.insights, {
      locale,
      populate: { insight_category: true },
      pagination: { pageSize: 500 },
    });
    const insights = Array.isArray(res?.data) ? res.data : [];
    for (const insight of insights) {
      const categorySlug = insight.insight_category && typeof insight.insight_category === 'object' && 'slug' in insight.insight_category
        ? (insight.insight_category as InsightCategoryAttributes).slug
        : '';
      if (categorySlug && insight.slug) {
        paths.push({ params: { locale, category: categorySlug, slug: insight.slug } });
      }
    }
  }
  return paths;
}

const params = Astro.params as { locale?: string; category?: string; slug?: string };
const locale: Locale = getLocale(params.locale);
const categorySlug = params.category ?? '';
const articleSlug = params.slug ?? '';
const messages = await loadMessages(locale);

const articleRes = await fetchApiWithLocaleFallback<{ data?: InsightAttributes[] }>(api.insights, {
  locale,
  populate: {
    insight_category: true,
    cover: true,
    seo: {
      populate: {
        metaImage: true,
        ogImage: true,
        twitterImage: true,
      },
    },
    products: { populate: { cover: true, images: true, category: true } },
    articles: { populate: { cover: true } },
  },
  filters: {
    $and: [
      { insight_category: { slug: { $eq: categorySlug } } },
      { slug: { $eq: articleSlug } },
    ],
  },
});
const article = articleRes?.data?.[0];

if (!article) {
  return Astro.redirect(toHref('/about/insights', locale));
}

const categoryName = article.insight_category && typeof article.insight_category === 'object' && 'name' in article.insight_category
  ? (article.insight_category as InsightCategoryAttributes).name
  : categorySlug;

const relatedProducts = (article as { products?: ProductAttributes[] })?.products ?? [];
const relatedArticles = (article as { articles?: InsightAttributes[] })?.articles ?? [];

const publishedDate = article.publishedAt
  ? new Date(article.publishedAt).toLocaleDateString(localeDateTag[locale], {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : '';

const breadcrumbItems = [
  { label: t(messages, 'pageTitle.home'), href: '/' },
  { label: t(messages, 'footer.about.insights'), href: '/about/insights' },
  { label: categoryName, href: `/about/insights/${categorySlug}` },
  { label: article.title, href: undefined },
];
const pageTitle = `${article.title} - ${t(messages, 'footer.about.insights')}`;

const markdownResult = article.content ? await renderMarkdownWithTOC(article.content, article.title) : { html: '', toc: [] };
const articleHtml = markdownResult.html;
const tocItems = markdownResult.toc;
---

<BaseLayout
  title={pageTitle}
  description={article.description || article.excerpt}
  image={article.cover}
  seo={article.seo}
  pageType="article"
  breadcrumbs={breadcrumbItems}
  publishedTime={article.publishedAt}
  modifiedTime={article.updatedAt}
  messages={messages}
  locale={locale}
>
  <div class="container mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} locale={locale} />

    <div class="flex flex-col gap-10 lg:flex-row lg:items-start">
      <article class="min-w-0 flex-1 max-w-[820px]">
        <header class="mb-10 border-b border-slate-200 pb-8">
          <div class="mb-4 flex flex-wrap items-center gap-3">
            <span class="inline-flex items-center rounded-full bg-orange-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-orange-600">
              {categoryName}
            </span>
            {publishedDate && (
              <span class="text-sm font-medium text-slate-500">
                {publishedDate}
              </span>
            )}
          </div>
          <h1 class="mb-4 text-4xl font-black leading-tight text-slate-950 lg:text-5xl">{article.title}</h1>
          {article.excerpt && article.description && article.excerpt !== article.description && (
            <p class="mb-4 text-base font-medium uppercase tracking-[0.08em] text-slate-500">
              {article.excerpt}
            </p>
          )}
          {!article.description && article.excerpt && (
            <p class="mb-8 max-w-[760px] text-xl leading-8 text-slate-600">
              {article.excerpt}
            </p>
          )}
          {article.description && (
            <p class="mb-8 max-w-[760px] text-xl leading-8 text-slate-600">
              {article.description}
            </p>
          )}
        </header>
        {articleHtml && (
          <div class="article-content prose prose-lg max-w-none mb-16" set:html={articleHtml} />
        )}
        <ArticleSampleCta locale={locale} messages={messages} />
      </article>
      {tocItems.length > 0 && (
        <TableOfContents items={tocItems} locale={locale} messages={messages} />
      )}
    </div>

    {relatedProducts.length > 0 && (
      <section class="mt-20 border-t border-slate-200 pt-12">
        <p class="mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-orange-500">
          Product references
        </p>
        <h2 class="mb-3 text-3xl font-extrabold text-slate-950">{t(messages, 'helpCenter.relatedProducts')}</h2>
        <p class="mb-8 max-w-3xl text-base leading-7 text-slate-600">
          Explore the products referenced in this article to move from technical reading into evaluation and sourcing.
        </p>
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          {relatedProducts.map((product) => (
            <ProductCard product={product} locale={locale} />
          ))}
        </div>
      </section>
    )}

    {relatedArticles.length > 0 && (
      <section class="mt-20 border-t border-slate-200 pt-12">
        <p class="mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-orange-500">
          Continue reading
        </p>
        <h2 class="mb-3 text-3xl font-extrabold text-slate-950">{t(messages, 'helpCenter.relatedArticles')}</h2>
        <p class="mb-8 max-w-3xl text-base leading-7 text-slate-600">
          Read the next articles in this topic cluster for more application guidance, process detail, and product context.
        </p>
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          {relatedArticles.map((insight) => {
            const category = insight.insight_category && typeof insight.insight_category === 'object' && 'slug' in insight.insight_category
              ? insight.insight_category
            : null;
            const insightCategorySlug = category?.slug ?? categorySlug;
            const insightHref = insight.slug
              ? toHref(`/about/insights/${insightCategorySlug}/${insight.slug}`, locale)
              : '#';
            return <InsightCard insight={insight} locale={locale} href={insightHref} />;
          })}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
