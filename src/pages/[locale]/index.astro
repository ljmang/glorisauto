---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.svelte";
import { supportedLocales, type Locale, getLocale } from "@/i18n/config";
import { loadMessages, t } from "@/i18n";
import {
	fetchApiWithLocaleFallback,
	api,
	parseHeroMedia,
	parseImage,
} from "@/utils/strapiApi";
import { toHref } from "@/utils/navigationData";
import { CircleChevronRight } from "lucide-svelte";
import type { HomeAttributes, StrapiResponse, NewsItem } from "@/types";
import type { ProductAttributes, InsightAttributes } from "@/types/content";
import { Image } from "astro:assets";
import NewsCard from "@/components/NewsCard.astro";
import ProductCard from "@/components/ProductCard.astro";
import InsightCard from "@/components/InsightCard.astro";
import DownloadFileCard from "@/components/DownloadFileCard.astro";

export async function getStaticPaths() {
	return supportedLocales.map((locale) => ({
		params: { locale },
	}));
}

// 2. 从 params 获取 locale，并断言类型 (因为 params 默认是 string)
const params = Astro.params as { locale?: string };
const locale: Locale = getLocale(params.locale);

const messages = await loadMessages(locale);

// 3. 使用泛型获取数据，避免 unknown
const homeData = await fetchApiWithLocaleFallback<StrapiResponse<HomeAttributes>>(api.home, {
	locale,
	populate: {
		heroMedia: true,
		aboutGlorisCover: true,
		seo: {
			populate: {
				metaImage: true,
				ogImage: true,
				twitterImage: true,
			},
		},
		glorisNews: {
			populate: {
				cover: true,
			},
		},
		products: {
			populate: {
				cover: true,
				images: true,
				category: true,
			},
		},
		insights: {
			populate: {
				cover: true,
				insight_category: true,
			},
		},
		downloadFiles: {
			populate: {
				file: true,
			},
		},
	},
});
// 4. 安全的数据解构 (即使 API 挂了，页面也不会白屏，而是显示默认值)
const data = homeData?.data || ({} as Partial<HomeAttributes>);

const normalizeInsightsCount = (value: number | undefined, fallback: number) =>
	typeof value === "number" && Number.isFinite(value) && value > 0
		? Math.floor(value)
		: fallback;

const homeInsightsMode = data.insightsMode === "latest" ? "latest" : "manual";
const homeInsightsCount = normalizeInsightsCount(data.insightsCount, 3);
const manualInsights = Array.isArray(data.insights)
	? (data.insights as InsightAttributes[])
	: [];

const latestInsightsRes =
	Boolean(data.insightsTitle) && homeInsightsMode === "latest"
		? await fetchApiWithLocaleFallback<{ data?: InsightAttributes[] }>(
				api.insights,
				{
					locale,
					populate: {
						cover: true,
						insight_category: true,
					},
					sort: ["publishedAt:desc"],
					pagination: { pageSize: homeInsightsCount },
				},
			)
		: null;

const latestInsights = Array.isArray(latestInsightsRes?.data)
	? latestInsightsRes.data.filter((insight) => Boolean(insight?.slug))
	: [];
const displayInsights =
	homeInsightsMode === "latest"
		? latestInsights
		: manualInsights.slice(0, homeInsightsCount);
const showInsights = Boolean(data.insightsTitle) && displayInsights.length > 0;
const aboutGlorisLinkLabel =
	data.aboutGlorisLinkLabel?.trim() || t(messages, "common.readMore");
const aboutGlorisLinkHref = toHref(data.aboutGlorisLink?.trim() || "/about", locale);
const productsLinkLabel =
	data.productsLinkLabel?.trim() || t(messages, "common.viewAll");
const productsLinkHref = toHref(data.productsLink?.trim() || "/products", locale);
const insightsLinkLabel =
	data.insightsLinkLabel?.trim() || t(messages, "common.viewAll");
const insightsLinkHref = toHref(
	data.insightsLink?.trim() || "/about/insights",
	locale,
);
const downloadFilesLinkLabel =
	data.downloadFilesLinkLabel?.trim() || t(messages, "common.viewAll");
const downloadFilesLinkHref = toHref(
	data.downloadFilesLink?.trim() || "/support/download",
	locale,
);

// 处理数据
const heroMediaProp = parseHeroMedia(data.heroMedia);
const heroTitle = data.heroTitle ?? t(messages, "home.heroTitle");
const heroCtaHref = toHref(data.heroButtonLink ?? "/", locale);
const heroSampleCta = t(messages, "home.freeSampleCta");
const heroSampleCtaHref = `${toHref("/support/customer-service", locale)}?type=free-sample`;
const aboutGlorisCover = parseImage(data.aboutGlorisCover);
const showDownloadFiles =
	Boolean(data.downloadFilesTitle) &&
	Array.isArray(data.downloadFiles) &&
	data.downloadFiles.length > 0;
type DownloadFileItem = {
	title?: string;
	description?: string;
	file?: { url?: string; name?: string; ext?: string } | null;
};
const downloadFileList = ((data.downloadFiles as DownloadFileItem[]) || []).filter(
	(item) => item?.file?.url,
);
const homeProducts = (((data.products as (ProductAttributes & { sort?: number | null })[]) || [])
	.map((product, index) => ({ product, index }))
	.sort((a, b) => {
		const aSort = a.product.sort;
		const bSort = b.product.sort;
		const aHasSort = typeof aSort === "number";
		const bHasSort = typeof bSort === "number";

		if (aHasSort && bHasSort && aSort !== bSort) return aSort - bSort;
		if (aHasSort !== bHasSort) return aHasSort ? -1 : 1;
		const aDocumentId = (a.product as ProductAttributes & { documentId?: string }).documentId ?? "";
		const bDocumentId = (b.product as ProductAttributes & { documentId?: string }).documentId ?? "";
		if (aDocumentId && bDocumentId && aDocumentId !== bDocumentId) {
			return aDocumentId.localeCompare(bDocumentId);
		}
		return a.index - b.index;
	})
	.map(({ product }) => product));
---

<BaseLayout
	title={t(messages, "pageTitle.home")}
	description={data.heroDescription}
	image={data.aboutGlorisCover ?? data.heroMedia}
	seo={data.seo}
	pageType="website"
	messages={messages}
	locale={locale}
>
	<Hero
		client:load
		media={heroMediaProp}
		title={heroTitle}
		subtitle={data.heroDescription}
		cta={data.heroButton}
		ctaHref={heroCtaHref}
		secondaryCta={heroSampleCta}
		secondaryCtaHref={heroSampleCtaHref}
	/>

	<div
		class="container mx-auto px-4 py-6 lg:py-12 flex flex-col gap-6 lg:gap-12"
	>
		<!-- 品牌故事 -->
		<div class="flex flex-col lg:flex-row items-center bg-white">
			{
				aboutGlorisCover &&
					aboutGlorisCover.width &&
					aboutGlorisCover.height && (
						<Image
							src={aboutGlorisCover.src}
							alt={
								aboutGlorisCover.alt ||
								data.aboutGlorisTitle ||
								"Company Image"
							}
							width={aboutGlorisCover.width}
							height={aboutGlorisCover.height}
							class="w-full lg:w-1/3 h-auto object-cover"
							loading="lazy"
							format="webp"
							quality={100}
						/>
					)
			}
				<div class="flex flex-col gap-3 lg:gap-6 p-4 lg:p-16">
					{
						data.aboutGlorisTitle && (
							<p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-600">
								{data.aboutGlorisTitle}
							</p>
						)
					}
					<h3 class="text-4xl font-bold">
						{data.aboutGlorisTitleH1}
					</h3>
				<h4 class="text-2xl font-bold">
					{data.aboutGlorisTitleH2}
				</h4>
				<p class="text-lg text-gray-700">
					{data.aboutGlorisDescription}
				</p>
					<a
						href={aboutGlorisLinkHref}
						class="text-cyan-600 text-lg flex items-center gap-2 hover:text-orange-600 transition-colors"
					>
						{aboutGlorisLinkLabel}
						<CircleChevronRight class="w-4 h-4" />
					</a>
				</div>
			</div>

		<!-- Gloris News 新闻卡片 -->
			{
				data.glorisNewsTitle && (
					<div class="w-full space-y-6">
						<h2 class="text-3xl font-bold">
							{data.glorisNewsTitle as string}
						</h2>
						<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
							{((data.glorisNews as NewsItem[]) || []).map((news) => (
								<NewsCard news={news} locale={locale} />
							))}
						</div>
					</div>
				)
			}

		<!-- Products 产品展示 -->
		{
			data.productsTitle && (
				<div class="w-full">
					<div class="flex items-center justify-between mb-6">
							<h2 class="text-3xl font-bold">
								{data.productsTitle as string}
							</h2>
							<a
								href={productsLinkHref}
								class="text-cyan-600 text-lg flex items-center gap-2 hover:text-orange-600 transition-colors"
							>
								{productsLinkLabel}
								<CircleChevronRight class="w-4 h-4" />
							</a>
						</div>
					<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
						{homeProducts.map(
							(product) => (
								<ProductCard
									product={product}
									locale={locale}
								/>
							),
						)}
					</div>
				</div>
			)
		}

		<!-- Insights 文章/洞察展示 -->
		{
			showInsights && (
				<div class="w-full">
					<div class="flex items-center justify-between mb-6">
							<h2 class="text-3xl font-bold">
								{data.insightsTitle as string}
							</h2>
							<a
								href={insightsLinkHref}
								class="text-cyan-600 text-lg flex items-center gap-2 hover:text-orange-600 transition-colors"
							>
								{insightsLinkLabel}
								<CircleChevronRight class="w-4 h-4" />
							</a>
						</div>
					<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
						{displayInsights.map(
							(insight) => (
								<InsightCard
									insight={insight}
									locale={locale}
								/>
							),
						)}
					</div>
				</div>
			)
		}

		<!-- Download files 下载文件 -->
		{showDownloadFiles && (
			<div class="w-full">
				<div class="flex items-center justify-between mb-6">
						<h2 class="text-3xl font-bold">
							{data.downloadFilesTitle as string}
						</h2>
						<a
							href={downloadFilesLinkHref}
							class="text-cyan-600 text-lg flex items-center gap-2 hover:text-orange-600 transition-colors"
						>
							{downloadFilesLinkLabel}
							<CircleChevronRight class="w-4 h-4" />
						</a>
					</div>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
					{downloadFileList.map((fileItem) => (
						<DownloadFileCard
							item={fileItem}
							downloadLabel={t(messages, "footer.support.download")}
						/>
					))}
				</div>
			</div>
		)}
	</div>
</BaseLayout>
