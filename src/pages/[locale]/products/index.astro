---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { supportedLocales, type Locale, getLocale, isRtlLocale } from '@/i18n/config';
import { loadMessages, t } from '@/i18n';
import { fetchApi, api } from '@/utils/strapiApi';
import { toHref } from '@/utils/navigationData';
import { buildCategoryTree } from '@/utils/categoryTree';
import { resolveCollectionPageCopy } from '@/utils/collectionPageCopy';
import { fetchSiteSeo } from '@/utils/siteConfig';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ProductCard from '@/components/ProductCard.astro';
import type { ProductAttributes } from '@/types/content';
import type { CategoryAttributes } from '@/types/content';

export async function getStaticPaths() {
  return supportedLocales.map((locale) => ({
    params: { locale },
  }));
}

const params = Astro.params as { locale?: string };
const locale: Locale = getLocale(params.locale);
const isRtl = isRtlLocale(locale);
const messages = await loadMessages(locale);

const [categoriesRes, productsRes, siteSeo] = await Promise.all([
  fetchApi<{ data?: CategoryAttributes[] }>(api.categories, {
    locale,
    populate: { parent: true },
    pagination: { pageSize: 100 }
  }),
  fetchApi<{ data?: ProductAttributes[] }>(api.products, {
    locale,
    populate: { cover: true, images: true, category: true },
    pagination: { pageSize: 100 },
  }),
  fetchSiteSeo(locale),
]);

// 分类列表（扁平），再构建为一级/二级树
const categories = Array.isArray(categoriesRes?.data) ? categoriesRes.data : [];
const categoryTree = buildCategoryTree(categories);

const products = Array.isArray(productsRes?.data) ? productsRes.data : [];

const breadcrumbItems = [
  { label: t(messages, 'pageTitle.home'), href: '/' },
  { label: t(messages, 'pageTitle.products') },
];
const pageTitle = t(messages, 'products.allProducts');
const pageCopy = resolveCollectionPageCopy(locale, 'products', siteSeo);
---

<BaseLayout
  title={pageCopy.seoTitle}
  description={pageCopy.seoDescription}
  pageType="collection"
  breadcrumbs={breadcrumbItems}
  messages={messages}
  locale={locale}
>
  <div class="container mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} locale={locale} />

    <div class="flex flex-col md:flex-row gap-4 md:gap-8">
      <!-- 左侧：产品分类（滚动后吸顶，top 预留顶栏高度） -->
      <aside class="md:w-56 shrink-0 font-bold md:sticky md:top-60 md:self-start hidden md:block">
        <ul class="overflow-hidden">
          <li>
            <a
              href={toHref('/products', locale)}
              class="block p-2    hover:bg-gray-100 hover:text-orange-500 transition-colors"
            >
              {pageTitle}
            </a>
          </li>
          {categoryTree.map((root) => (
            root.children.length > 0 ? (
              <li>
                <a
                  href={toHref(`/products/${root.slug}`, locale)}
                  class="block p-2 font-semibold uppercase tracking-wide hover:bg-gray-100 hover:text-orange-500 transition-colors"
                >
                  {root.name}
                </a>
                <ul class={`border-gray-200 ${isRtl ? 'border-r mr-2 pr-2' : 'border-l ml-2 pl-2'}`}>
                  {root.children.map((child) => (
                    <li>
                      <a
                        href={toHref(`/products/${child.slug}`, locale)}
                        class="block p-2 hover:text-orange-500 transition-colors font-normal"
                      >
                        {child.name}
                      </a>
                    </li>
                  ))}
                </ul>
              </li>
            ) : (
              <li>
                <a
                  href={toHref(`/products/${root.slug}`, locale)}
                  class="block p-2 hover:bg-gray-100 hover:text-orange-500 transition-colors"
                >
                  {root.name}
                </a>
              </li>
            )
          ))}
        </ul>
      </aside>

      <!-- 右侧：产品列表 -->
      <main class="flex-1 min-w-0 mb-12 ">
        <h1 class="text-4xl lg:text-6xl font-black mb-4">{pageCopy.heading}</h1>
        <p class="max-w-4xl text-base leading-7 text-gray-600 mb-8 lg:text-lg lg:leading-8">
          {pageCopy.intro}
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
          {products.length > 0 ? (
            products.map((product) => (
              <ProductCard
                product={product}
                locale={locale}
                ctaLabel={t(messages, 'common.readMore')}
              />
            ))
          ) : (
            <p class="text-gray-500 col-span-full">{t(messages, 'search.noResults')}</p>
          )}
        </div>
      </main>
    </div>
  </div>
</BaseLayout>
