---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { supportedLocales, type Locale, getLocale } from '@/i18n/config';
import { loadMessages, t } from '@/i18n';
import { fetchApi, api, parseImage, parseMediaItems, getMediaUrl } from '@/utils/strapiApi';
import { toHref } from '@/utils/navigationData';
import { getFreeSampleHref } from '@/utils/freeSampleLink';
import { markdownToHtml } from '@/utils/markdown';
import { hasMeaningfulText, sanitizeInlineText, sanitizeMarkdown } from '@/utils/contentSanitizers';
import type { BlockNode } from '@/types/blocks';
import BlocksRenderer from '@/components/BlocksRenderer.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ProductGallery from '@/components/ProductGallery.astro';
import DownloadFileCard from '@/components/DownloadFileCard.astro';
import InsightCard from '@/components/InsightCard.astro';
import { CircleChevronRight, Gift, MessageCircle } from 'lucide-svelte';
import type { HelpCenterAttributes, InsightAttributes, ProductAttributes } from '@/types/content';

export async function getStaticPaths() {
  const paths: { params: { locale: string; category: string; slug: string } }[] = [];
  for (const locale of supportedLocales) {
    const res = await fetchApi<{ data?: (ProductAttributes & { category?: { slug?: string } })[] }>(api.products, {
      locale,
      populate: { cover: true, images: true, category: true },
      pagination: { pageSize: 500 },
    });
    const list = Array.isArray(res?.data) ? res.data : [];
    for (const product of list) {
      const slug = product.slug;
      const categorySlug =
        product.category && typeof product.category === 'object' && 'slug' in product.category
          ? (product.category as { slug?: string }).slug
          : '';
      if (slug && categorySlug) {
        paths.push({ params: { locale, category: categorySlug, slug } });
      }
    }
  }
  return paths;
}

const params = Astro.params as { locale?: string; category?: string; slug?: string };
const locale: Locale = getLocale(params.locale);
const categorySlug = params.category ?? '';
const productSlug = params.slug ?? '';
const messages = await loadMessages(locale);

type ProductResponse = { data?: ProductAttributes[] };

const productBasePopulate = {
  images: true,
  cover: true,
  category: true,
  seo: {
    populate: {
      metaImage: true,
      ogImage: true,
      twitterImage: true,
    },
  },
  information: true,
  technicalDetails: true,
  options: true,
  hole: true,
  downloadFiles: { populate: { file: true } },
  help_centers: { populate: { help_category: true } },
  insights: { populate: { cover: true, insight_category: true } },
};

const productFilters = {
  slug: { $eq: productSlug },
  category: { slug: { $eq: categorySlug } },
};

const productsRes = await fetchApi<ProductResponse>(api.products, {
  locale,
  populate: productBasePopulate,
  filters: productFilters,
  pagination: { pageSize: 1 },
});

const product = Array.isArray(productsRes?.data) && productsRes.data.length > 0 ? productsRes.data[0] : null;
const category = (product as { category?: { slug?: string; name?: string } } | null)?.category;
const categoryName = category?.name ?? categorySlug;

const productCoverImage = product ? parseImage(product.cover) : null;
const productMedia = product ? parseMediaItems(product.images) : [];
const productGalleryMedia =
  productMedia.length > 0
    ? productMedia.map((media) =>
        media.type === 'video' && !media.poster && productCoverImage?.src
          ? { ...media, poster: productCoverImage.src }
          : media
      )
    : productCoverImage
      ? [{ type: 'image' as const, ...productCoverImage }]
      : [];
const productSeoImage = productCoverImage ?? productGalleryMedia.find((media) => media.type === 'image') ?? null;
const rawInformationList = (product as { information?: { title?: string; description?: BlockNode[] }[] } | null)?.information ?? [];
const informationList = rawInformationList
  .map((item) => ({
    title: sanitizeInlineText(item?.title ?? ''),
    description: item?.description ?? [],
  }))
  .filter((item) => item.title || item.description.length > 0);
const rawTechnicalDetailsList =
  (product as { technicalDetails?: { title?: string; description?: string }[] } | null)?.technicalDetails ?? [];
const technicalDetailsList = rawTechnicalDetailsList
  .map((item) => ({
    title: sanitizeInlineText(item?.title ?? ''),
    description: sanitizeInlineText(item?.description ?? ''),
  }))
  .filter((item) => hasMeaningfulText(item.title) && hasMeaningfulText(item.description));
const optionsList = ((product as { options?: { name?: string }[] } | null)?.options ?? [])
  .map((item) => ({ name: sanitizeInlineText(item?.name ?? '') }))
  .filter((item) => item.name);
const holeList = ((product as { hole?: { name?: string }[] } | null)?.hole ?? [])
  .map((item) => ({ name: sanitizeInlineText(item?.name ?? '') }))
  .filter((item) => item.name);
const productFeaturesMarkdown = sanitizeMarkdown((product as { productFeatures?: string } | null)?.productFeatures ?? '');
const productFeaturesHtml = await markdownToHtml(productFeaturesMarkdown, product?.name);
const productFeaturesHtmlWithScrollableTables = productFeaturesHtml
  .replace(/<table>/g, '<div class="product-features-table-scroll"><table>')
  .replace(/<\/table>/g, '</table></div>');
const productDescription = sanitizeInlineText(product?.description ?? '');

type DownloadFileEntry = {
  title?: string;
  description?: string;
  file?: { url?: string; name?: string; ext?: string; size?: number };
};
const rawDownloads = (product as { downloadFiles?: DownloadFileEntry[] } | null)?.downloadFiles ?? [];
const downloadFilesList = rawDownloads.map((d) => ({
  title: sanitizeInlineText(d?.title ?? ''),
  description: sanitizeInlineText(d?.description ?? ''),
  file: d?.file ? { ...d.file, url: d.file.url ? getMediaUrl(d.file.url) : undefined } : undefined,
}));

type ProductHelpCenterEntry = Partial<Pick<HelpCenterAttributes, 'title' | 'slug' | 'contentMarkdown'>> & {
  help_category?: { slug?: string } | null;
};

const relatedHelpCenters = Array.isArray((product as { help_centers?: ProductHelpCenterEntry[] } | null)?.help_centers)
  ? ((product as { help_centers?: ProductHelpCenterEntry[] }).help_centers ?? [])
  : [];

type ProductInsightEntry = InsightAttributes & {
  id?: string | number;
  documentId?: string;
  cover?: unknown;
};

const relatedInsights = Array.isArray((product as { insights?: ProductInsightEntry[] } | null)?.insights)
  ? ((product as { insights?: ProductInsightEntry[] }).insights ?? [])
  : [];
const relatedInsightItems: ProductInsightEntry[] = [];

function getInsightKey(insight: ProductInsightEntry): string {
  if (insight.documentId) return `document:${insight.documentId}`;
  if (insight.id != null) return `id:${insight.id}`;

  const category = insight.insight_category && typeof insight.insight_category === 'object' ? insight.insight_category : null;
  const categorySlug = category?.slug ?? '';
  if (insight.slug) return `slug:${categorySlug}:${insight.slug}`;

  return `title:${insight.title}`;
}

for (const insight of relatedInsights) {
  if (!insight?.slug || !insight?.title) continue;

  const key = getInsightKey(insight);
  const exists = relatedInsightItems.some((existingInsight) => getInsightKey(existingInsight) === key);
  if (!exists) relatedInsightItems.push(insight);
}

type HelpCenterItem = {
  title?: string;
  slug?: string;
  contentMarkdown?: string;
  contentHtml?: string;
  href?: string;
};

const faqItems: HelpCenterItem[] = [];

async function buildHelpCenterItem(entry: ProductHelpCenterEntry): Promise<HelpCenterItem | null> {
  const markdown = entry.contentMarkdown?.trim() ?? '';
  if (!markdown) return null;

  const catSlug = entry.help_category?.slug ?? '';
  const href = catSlug && entry.slug ? toHref(`/help/${catSlug}/${entry.slug}`, locale) : '';

  return {
    title: entry.title,
    slug: entry.slug,
    contentMarkdown: markdown,
    contentHtml: await markdownToHtml(markdown, entry.title),
    href,
  };
}

function getFaqItemKey(item: HelpCenterItem): string {
  return item.href || item.slug || item.title || item.contentMarkdown || '';
}

async function addFaqItem(entry: ProductHelpCenterEntry): Promise<void> {
  const item = await buildHelpCenterItem(entry);
  if (!item) return;

  const key = getFaqItemKey(item);
  const exists = faqItems.some((existingItem) => getFaqItemKey(existingItem) === key);
  if (!exists) faqItems.push(item);
}

for (const relatedHelpCenter of relatedHelpCenters) {
  await addFaqItem(relatedHelpCenter);
}

const isFilmMasterPage = categorySlug === 'film-sanding-disc' && productSlug === 'film-master-sanding-disc';
if (isFilmMasterPage) {
  const commonFaqRes = await fetchApi<{ data?: Array<{ title?: string; slug?: string; contentMarkdown?: string; help_category?: { slug?: string } }> }>(api.helpCenters, {
    locale,
    filters: { slug: { $eq: 'common-abrasive-backing-materials' } },
    populate: { help_category: true },
    pagination: { pageSize: 1 },
  });
  const commonFaq = Array.isArray(commonFaqRes?.data) && commonFaqRes.data.length > 0 ? commonFaqRes.data[0] : null;
  if (commonFaq) {
    await addFaqItem(commonFaq);
  }
}

const breadcrumbItems = [
  { label: t(messages, 'pageTitle.home'), href: '/' },
  { label: t(messages, 'pageTitle.products'), href: '/products' },
  { label: categoryName, href: `/products/${categorySlug}` },
  { label: product?.name ?? productSlug },
];
---

<BaseLayout
  title={product ? `${product.name} - ${t(messages, 'pageTitle.products')}` : t(messages, 'pageTitle.products')}
  description={productDescription}
  image={product?.cover ?? (productSeoImage ? { url: productSeoImage.src } : undefined)}
  seo={product?.seo}
  pageType="product"
  breadcrumbs={breadcrumbItems}
  messages={messages}
  locale={locale}
>
  <div class='container mx-auto px-4 py-8'>
    {product ? (
      <>
        <Breadcrumb items={breadcrumbItems} locale={locale} />

        <section class='mb-12 grid gap-8 lg:grid-cols-2 lg:gap-12'>
          <div class='lg:min-w-0'>
            <ProductGallery media={productGalleryMedia} productName={product.name ?? ''} />
          </div>
          <div>
            <h1 class='text-3xl font-bold md:text-4xl'>{product.name}</h1>

            {informationList.length > 0 && (
              <div class='mt-6'>
                {informationList.map((item) => (
                  <div class='mb-4'>
                    {item.title && <h2 class='text-lg font-semibold mb-2'>{item.title}</h2>}
                    {item.description && item.description.length > 0 && <BlocksRenderer blocks={item.description} />}
                  </div>
                ))}
              </div>
            )}

            {informationList.length === 0 && productDescription && (
              <div class='prose prose-lg mt-6'>
                <p>{productDescription}</p>
              </div>
            )}

            {(holeList.length > 0 || optionsList.length > 0) && (
              <div class='mt-4 space-y-2'>
                {holeList.map((h) => <p>{h.name ?? ''}</p>)}
              </div>
            )}

            {optionsList.length > 0 && (
              <div class='mt-6'>
                <p class='font-semibold mb-2'>{t(messages, 'products.gritOptions')}</p>
                <div class='flex flex-wrap gap-2'>
                  {optionsList.map((opt) => (
                    <span class='rounded border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium text-gray-700 transition-colors hover:border-gray-400'>
                      {opt.name ?? ''}
                    </span>
                  ))}
                </div>
              </div>
            )}

            <!-- 行动按钮 -->
            <div class='mt-8 flex flex-wrap gap-4'>
              <a
                href={getFreeSampleHref(locale)}
                class='inline-flex items-center justify-center gap-2 rounded-md bg-orange-500 px-6 py-3 font-medium text-white transition-colors hover:bg-orange-600'
              >
                <Gift class="h-5 w-5 shrink-0" />
                {t(messages, 'home.freeSampleCta')}
              </a>
              <button
                type="button"
                data-open-live-chat
                class='inline-flex items-center justify-center gap-2 rounded-md border border-orange-400 bg-white px-6 py-3 font-medium text-orange-500 transition-colors hover:bg-gray-100'
              >
                <MessageCircle class="h-5 w-5 shrink-0" />
                {t(messages, 'products.leaveMessage')}
              </button>
            </div>
          </div>
        </section>

        {technicalDetailsList.length > 0 && (
          <section class='mb-12'>
            <h2 class='text-3xl font-bold mb-4'>{t(messages, 'products.technicalDetails')}</h2>
            <div class='grid gap-x-8 grid-cols-1 lg:grid-cols-2'>
              {technicalDetailsList.map((item) => (
                <div class='flex iten-center border-b border-gray-500 gap-2'>
                  {item.title != null && item.title !== '' && <div class='font-semibold bg-gray-200 p-3 w-1/2'>{item.title}</div>}
                  <div class='p-2'>{item.description ?? ''}</div>
                </div>
              ))}
            </div>
          </section>
        )}

        {productFeaturesHtml && (
          <section class='mb-12 max-w-5xl'>
            <h2 class='text-3xl font-bold mb-4'>{t(messages, 'products.features')}</h2>
            <div
              class='product-features-content prose prose-lg max-w-none text-gray-700 prose-headings:font-bold prose-a:text-cyan-600 prose-a:no-underline hover:prose-a:text-orange-600'
              set:html={productFeaturesHtmlWithScrollableTables}
            />
          </section>
        )}

        {downloadFilesList.length > 0 && (
          <section class='mb-12'>
            <div class='mb-4 flex items-center justify-between gap-4'>
              <h2 class='text-3xl font-bold'>{t(messages, 'products.downloads')}</h2>
              <a
                href={toHref('/support/download', locale)}
                class='flex shrink-0 items-center gap-2 text-lg text-cyan-600 transition-colors hover:text-orange-600'
              >
                {t(messages, 'common.viewAll')}
                <CircleChevronRight class='h-4 w-4' />
              </a>
            </div>
            <div class='grid gap-4 sm:grid-cols-2 lg:grid-cols-3'>
              {downloadFilesList.map((item) => (
                <DownloadFileCard item={item} downloadLabel={t(messages, 'footer.support.download')} />
              ))}
            </div>
          </section>
        )}

        {relatedInsightItems.length > 0 && (
          <section class='mb-12'>
            <div class='mb-6 flex items-center justify-between gap-4'>
              <h2 class='text-3xl font-bold'>{t(messages, 'products.relatedInsights')}</h2>
              <a
                href={toHref('/about/insights', locale)}
                class='flex shrink-0 items-center gap-2 text-lg text-cyan-600 transition-colors hover:text-orange-600'
              >
                {t(messages, 'common.viewAll')}
                <CircleChevronRight class='h-4 w-4' />
              </a>
            </div>
            <div class='grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3'>
              {relatedInsightItems.map((insight) => (
                <InsightCard insight={insight} locale={locale} />
              ))}
            </div>
          </section>
        )}

        {faqItems.length > 0 && (
          <section class='mb-12 max-w-5xl'>
            <div class='mb-4 flex items-center justify-between gap-4'>
              <h2 class='text-3xl font-bold'>{t(messages, 'products.faq')}</h2>
              <a
                href={toHref('/help', locale)}
                class='flex shrink-0 items-center gap-2 text-lg text-cyan-600 transition-colors hover:text-orange-600'
              >
                {t(messages, 'common.viewAll')}
                <CircleChevronRight class='h-4 w-4' />
              </a>
            </div>
            <div class='space-y-4'>
              {faqItems.map((faq, idx) => (
                <details class='rounded-lg border border-gray-200 bg-white' open={idx === 0 ? true : undefined}>
                  <summary class='cursor-pointer px-4 py-3 text-lg font-semibold text-gray-900'>
                    {faq.title || `${t(messages, 'products.faq')} ${idx + 1}`}
                  </summary>
                  <div class='px-4 pb-4 text-gray-700'>
                    {faq.contentHtml && (
                      <div class='prose max-w-none text-gray-700' set:html={faq.contentHtml} />
                    )}
                    {faq.href && (
                      <div class='mt-4'>
                        <a href={faq.href} class='flex items-center gap-2 font-medium text-cyan-600 hover:text-orange-600'>
                          {t(messages, 'common.readMore')}
                          <CircleChevronRight class='w-4 h-4' />
                        </a>
                      </div>
                    )}
                  </div>
                </details>
              ))}
            </div>
          </section>
        )}
      </>
    ) : (
      <p>{t(messages, 'search.noResults')}</p>
    )}
  </div>
</BaseLayout>

<script is:inline>
  (function () {
    const triggerSelector = '[data-open-live-chat]';
    const waitIntervalMs = 150;
    const maxWaitMs = 5000;

    function openLiveChat() {
      const api = window.Tawk_API;
      if (!api) return false;
      if (typeof api.maximize === 'function') {
        api.maximize();
        return true;
      }
      if (typeof api.toggle === 'function') {
        api.toggle();
        return true;
      }
      return false;
    }

    document.addEventListener('click', function (event) {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const trigger = target.closest(triggerSelector);
      if (!trigger) return;

      event.preventDefault();
      if (openLiveChat()) return;

      const startedAt = Date.now();
      const timer = window.setInterval(function () {
        if (openLiveChat() || Date.now() - startedAt >= maxWaitMs) {
          window.clearInterval(timer);
        }
      }, waitIntervalMs);
    });
  })();
</script>

<style>
  .product-features-content :global(.product-features-table-scroll) {
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    overscroll-behavior-x: contain;
    -webkit-overflow-scrolling: touch;
  }

  .product-features-content :global(.product-features-table-scroll table) {
    width: max-content;
    min-width: 100%;
    margin-top: 0;
    margin-bottom: 0;
  }
</style>
