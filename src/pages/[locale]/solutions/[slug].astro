---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import BlocksRenderer from '@/components/BlocksRenderer.astro';
import ProductCard from '@/components/ProductCard.astro';
import InsightCard from '@/components/InsightCard.astro';
import ArticleSampleCta from '@/components/ArticleSampleCta.astro';
import { supportedLocales, type Locale, getLocale } from '@/i18n/config';
import { loadMessages, t } from '@/i18n';
import { fetchApiWithLocaleFallback, api, parseImage } from '@/utils/strapiApi';
import { toHref } from '@/utils/navigationData';
import { isSolutionsEnabled } from '@/utils/featureFlags';
import type {
  CategoryAttributes,
  HelpCenterAttributes,
  InsightAttributes,
  InsightCategoryAttributes,
  ProductAttributes,
  SolutionAttributes,
} from '@/types/content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  if (!isSolutionsEnabled()) {
    return [];
  }

  const paths: { params: { locale: string; slug: string } }[] = [];
  for (const locale of supportedLocales) {
    const res = await fetchApiWithLocaleFallback<{ data?: SolutionAttributes[] }>(api.solutions, {
      locale,
      pagination: { pageSize: 200 },
    });
    const rows = Array.isArray(res?.data) ? res.data : [];
    for (const row of rows) {
      if (row.slug) paths.push({ params: { locale, slug: row.slug } });
    }
  }
  return paths;
}

const params = Astro.params as { locale?: string; slug?: string };
const locale: Locale = getLocale(params.locale);
const slug = params.slug ?? '';

if (!isSolutionsEnabled()) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}

const messages = await loadMessages(locale);

const solutionRes = await fetchApiWithLocaleFallback<{ data?: SolutionAttributes[] }>(api.solutions, {
  locale,
  filters: {
    slug: { $eq: slug },
  },
  populate: {
    cover: true,
    expectedResults: true,
    processSteps: true,
    decisionFactors: true,
    recommendedProducts: {
      populate: { cover: true, images: true, category: true },
    },
    relatedHelpCenters: {
      populate: { help_category: true },
    },
    relatedInsights: {
      populate: { cover: true, insight_category: true },
    },
    seo: {
      populate: {
        metaImage: true,
        ogImage: true,
        twitterImage: true,
      },
    },
  },
  pagination: { pageSize: 1 },
});

const solution = solutionRes?.data?.[0];

if (!solution) {
  return Astro.redirect(toHref('/solutions', locale));
}

const cover = parseImage(solution.cover);
const audience = Array.isArray(solution.targetAudience)
  ? solution.targetAudience
      .map((item) => ({
        name: item?.name?.trim() || '',
        image: parseImage(item?.image),
      }))
      .filter((item) => item.name)
  : [];
const problemPoints = Array.isArray(solution.problemPoints) ? solution.problemPoints : [];
const expectedResults = Array.isArray(solution.expectedResults) ? solution.expectedResults : [];
const processSteps = Array.isArray(solution.processSteps) ? solution.processSteps : [];
const recommendedProducts = Array.isArray(solution.recommendedProducts) ? solution.recommendedProducts : [];
const relatedHelpCenters = Array.isArray(solution.relatedHelpCenters) ? solution.relatedHelpCenters : [];
const relatedInsights = Array.isArray(solution.relatedInsights) ? solution.relatedInsights : [];
const decisionFactors = Array.isArray(solution.decisionFactors) ? solution.decisionFactors : [];
const overviewCount = Array.isArray(solution.overview) ? solution.overview.length : 0;
const trimText = (value?: string | null, maxLength = 160) => {
  const normalized = (value ?? '').replace(/\s+/g, ' ').trim();
  if (!normalized) return '';
  if (normalized.length <= maxLength) return normalized;

  const shortened = normalized.slice(0, maxLength);
  const lastSpace = shortened.lastIndexOf(' ');
  return `${(lastSpace > 72 ? shortened.slice(0, lastSpace) : shortened).trim()}...`;
};
const getProductCategory = (product: ProductAttributes): CategoryAttributes | null => {
  if (!product.category || typeof product.category !== 'object' || !('name' in product.category)) return null;
  return product.category as CategoryAttributes;
};
const featuredRecommendedProducts = recommendedProducts.slice(0, 3);
const featuredHelpCenters = relatedHelpCenters.slice(0, 3);
const featuredInsights = relatedInsights.slice(0, 3);
const pageSections = [
  audience.length > 0
    ? { id: 'best-fit', label: solution.audienceTitle || t(messages, 'solutions.audienceTitle'), count: audience.length }
    : null,
  problemPoints.length > 0
    ? { id: 'business-challenges', label: solution.problemPointsTitle || t(messages, 'solutions.problemPointsTitle'), count: problemPoints.length }
    : null,
  overviewCount > 0
    ? { id: 'solution-overview', label: solution.overviewTitle || t(messages, 'solutions.overviewTitle') }
    : null,
  expectedResults.length > 0
    ? { id: 'expected-results', label: solution.expectedResultsTitle || t(messages, 'solutions.expectedResultsTitle'), count: expectedResults.length }
    : null,
  processSteps.length > 0
    ? { id: 'recommended-process', label: solution.processTitle || t(messages, 'solutions.processTitle'), count: processSteps.length }
    : null,
  recommendedProducts.length > 0
    ? { id: 'recommended-products', label: solution.recommendedProductsTitle || t(messages, 'solutions.recommendedProductsTitle'), count: recommendedProducts.length }
    : null,
  decisionFactors.length > 0
    ? { id: 'decision-factors', label: solution.decisionFactorsTitle || t(messages, 'solutions.decisionFactorsTitle'), count: decisionFactors.length }
    : null,
  relatedHelpCenters.length > 0
    ? { id: 'related-guides', label: solution.relatedHelpCentersTitle || t(messages, 'solutions.relatedGuidesTitle'), count: relatedHelpCenters.length }
    : null,
  relatedInsights.length > 0
    ? { id: 'related-insights', label: solution.relatedInsightsTitle || t(messages, 'solutions.relatedInsightsTitle'), count: relatedInsights.length }
    : null,
].filter(Boolean);

const breadcrumbItems = [
  { label: t(messages, 'pageTitle.home'), href: '/' },
  { label: t(messages, 'pageTitle.solutions'), href: '/solutions' },
  { label: solution.title },
];

const pageTitle = `${solution.title} - ${t(messages, 'pageTitle.solutions')}`;
---

<BaseLayout
  title={pageTitle}
  description={solution.summary || solution.heroSubtitle}
  image={solution.cover}
  seo={solution.seo}
  pageType="collection"
  breadcrumbs={breadcrumbItems}
  messages={messages}
  locale={locale}
>
  <div class="container mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} locale={locale} />

    <article class="mx-auto max-w-6xl">
      <section class="grid gap-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(280px,0.9fr)] lg:items-center">
        <div>
          <h1 class="text-4xl font-black text-slate-950 lg:text-6xl">
            {solution.heroTitle || solution.title}
          </h1>
          {solution.heroSubtitle && (
            <p class="mt-4 max-w-3xl text-lg leading-8 text-gray-600">
              {solution.heroSubtitle}
            </p>
          )}
          {audience.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-2">
              {audience.map((item) => (
                <span class="border border-gray-300 px-3 py-1 text-xs font-semibold uppercase tracking-[0.12em] text-gray-600">
                  {item.name}
                </span>
              ))}
            </div>
          )}
          {solution.heroButtonLabel && solution.heroButtonUrl && (
            <div class="mt-8">
              <a
                href={toHref(solution.heroButtonUrl, locale)}
                class="inline-flex items-center justify-center rounded-md bg-orange-500 px-6 py-3 font-medium text-white transition-colors hover:bg-orange-600"
              >
                {solution.heroButtonLabel}
              </a>
            </div>
          )}
        </div>

        {cover?.src && (
          <div class="overflow-hidden border border-gray-200 bg-white">
            {cover.width && cover.height ? (
              <Image
                src={cover.src}
                alt={cover.alt || solution.title}
                width={cover.width}
                height={cover.height}
                class="h-full w-full object-cover"
                format="webp"
                quality={90}
              />
            ) : (
              <img src={cover.src} alt={cover.alt || solution.title} class="h-full w-full object-cover" />
            )}
          </div>
        )}
      </section>

      {(solution.summary || audience.length > 0 || recommendedProducts.length > 0 || relatedHelpCenters.length > 0 || relatedInsights.length > 0) && (
        <section class="mt-10 border border-slate-200 bg-slate-950 text-white">
          <div class="grid gap-8 px-6 py-8 lg:grid-cols-[minmax(0,1.2fr)_minmax(320px,0.8fr)] lg:px-8">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.18em] text-orange-300">
                {t(messages, 'solutions.atAGlance')}
              </p>
              {solution.summary && (
                <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-200">
                  {solution.summary}
                </p>
              )}
              {overviewCount > 0 && (
                <p class="mt-4 max-w-3xl text-sm leading-7 text-slate-300">
                  {t(messages, 'solutions.atAGlanceDescription', {
                    title: solution.heroTitle || solution.title,
                  })}
                </p>
              )}
            </div>

            <div class="grid grid-cols-2 gap-4 sm:grid-cols-4 lg:grid-cols-2">
              <div class="border border-white/10 bg-white/5 p-4">
                <p class="text-3xl font-black text-white">{audience.length || '-'}</p>
                <p class="mt-2 text-sm leading-6 text-slate-300">
                  {solution.audienceTitle || t(messages, 'solutions.audienceTitle')}
                </p>
              </div>
              <div class="border border-white/10 bg-white/5 p-4">
                <p class="text-3xl font-black text-white">{recommendedProducts.length || '-'}</p>
                <p class="mt-2 text-sm leading-6 text-slate-300">
                  {solution.recommendedProductsTitle || t(messages, 'solutions.recommendedProductsTitle')}
                </p>
              </div>
              <div class="border border-white/10 bg-white/5 p-4">
                <p class="text-3xl font-black text-white">{relatedHelpCenters.length || '-'}</p>
                <p class="mt-2 text-sm leading-6 text-slate-300">
                  {solution.relatedHelpCentersTitle || t(messages, 'solutions.relatedGuidesTitle')}
                </p>
              </div>
              <div class="border border-white/10 bg-white/5 p-4">
                <p class="text-3xl font-black text-white">{relatedInsights.length || '-'}</p>
                <p class="mt-2 text-sm leading-6 text-slate-300">
                  {solution.relatedInsightsTitle || t(messages, 'solutions.relatedInsightsTitle')}
                </p>
              </div>
            </div>
          </div>
        </section>
      )}

      {pageSections.length > 0 && (
        <section class="mt-8 border border-gray-200 bg-white p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-orange-500">
            {t(messages, 'solutions.pageSectionsTitle')}
          </p>
          <p class="mt-2 max-w-3xl text-sm leading-7 text-gray-600">
            {t(messages, 'solutions.pageSectionsDescription')}
          </p>

          <div class="mt-5 flex flex-wrap gap-3">
            {pageSections.map((section) => (
              <a
                href={`#${section.id}`}
                class="inline-flex items-center gap-2 border border-gray-200 bg-gray-50 px-4 py-2 text-sm font-semibold text-slate-700 transition-colors hover:border-orange-300 hover:text-orange-600"
              >
                <span>{section.label}</span>
                {'count' in section && typeof section.count === 'number' && <span class="text-xs text-gray-500">{section.count}</span>}
              </a>
            ))}
          </div>
        </section>
      )}

      {(recommendedProducts.length > 0 || relatedHelpCenters.length > 0 || relatedInsights.length > 0) && (
        <section class="mt-8 border border-gray-200 bg-gray-50/80 p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-orange-500">
            {t(messages, 'solutions.includedContentTitle')}
          </p>
          <p class="mt-2 max-w-3xl text-sm leading-7 text-gray-600">
            {t(messages, 'solutions.includedContentDescription')}
          </p>

          <div class="mt-6 grid gap-6 lg:grid-cols-3">
            {featuredRecommendedProducts.length > 0 && (
              <div class="flex h-full flex-col border border-gray-200 bg-white p-5">
                <div class="flex items-start justify-between gap-4">
                  <h2 class="text-lg font-black text-slate-950">
                    {solution.recommendedProductsTitle || t(messages, 'solutions.recommendedProductsTitle')}
                  </h2>
                  <a
                    href="#recommended-products"
                    class="shrink-0 text-xs font-semibold uppercase tracking-[0.14em] text-orange-600 transition-colors hover:text-orange-700"
                  >
                    {t(messages, 'common.viewAll')}
                  </a>
                </div>
                <ul class="mt-4 space-y-4">
                  {featuredRecommendedProducts.map((product: ProductAttributes) => {
                    const category = getProductCategory(product);
                    const categorySlug = category?.slug ?? '';
                    const href = categorySlug
                      ? toHref(`/products/${categorySlug}/${product.slug}`, locale)
                      : toHref(`/products/${product.slug}`, locale);
                    const summary = trimText(product.shortDescription || product.description, 156);
                    return (
                      <li class="border-t border-gray-100 pt-4 first:border-t-0 first:pt-0">
                        {category?.name && (
                          <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-orange-500">
                            {category.name}
                          </p>
                        )}
                        <a href={href} class="mt-2 block text-sm font-bold leading-6 text-slate-900 transition-colors hover:text-orange-600">
                          {product.name}
                        </a>
                        {summary && <p class="mt-2 text-sm leading-6 text-gray-600">{summary}</p>}
                      </li>
                    );
                  })}
                </ul>
              </div>
            )}

            {featuredHelpCenters.length > 0 && (
              <div class="flex h-full flex-col border border-gray-200 bg-white p-5">
                <div class="flex items-start justify-between gap-4">
                  <h2 class="text-lg font-black text-slate-950">
                    {solution.relatedHelpCentersTitle || t(messages, 'solutions.relatedGuidesTitle')}
                  </h2>
                  <a
                    href="#related-guides"
                    class="shrink-0 text-xs font-semibold uppercase tracking-[0.14em] text-orange-600 transition-colors hover:text-orange-700"
                  >
                    {t(messages, 'common.viewAll')}
                  </a>
                </div>
                <ul class="mt-4 space-y-4">
                  {featuredHelpCenters.map((article: HelpCenterAttributes) => {
                    const categorySlug = article.help_category?.slug ?? '';
                    const href = categorySlug && article.slug ? toHref(`/help/${categorySlug}/${article.slug}`, locale) : '#';
                    const summary = trimText(article.description, 156);
                    return (
                      <li class="border-t border-gray-100 pt-4 first:border-t-0 first:pt-0">
                        {article.help_category?.name && (
                          <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-orange-500">
                            {article.help_category.name}
                          </p>
                        )}
                        <a href={href} class="mt-2 block text-sm font-bold leading-6 text-slate-900 transition-colors hover:text-orange-600">
                          {article.title}
                        </a>
                        {summary && <p class="mt-2 text-sm leading-6 text-gray-600">{summary}</p>}
                      </li>
                    );
                  })}
                </ul>
              </div>
            )}

            {featuredInsights.length > 0 && (
              <div class="flex h-full flex-col border border-gray-200 bg-white p-5">
                <div class="flex items-start justify-between gap-4">
                  <h2 class="text-lg font-black text-slate-950">
                    {solution.relatedInsightsTitle || t(messages, 'solutions.relatedInsightsTitle')}
                  </h2>
                  <a
                    href="#related-insights"
                    class="shrink-0 text-xs font-semibold uppercase tracking-[0.14em] text-orange-600 transition-colors hover:text-orange-700"
                  >
                    {t(messages, 'common.viewAll')}
                  </a>
                </div>
                <ul class="mt-4 space-y-4">
                  {featuredInsights.map((insight: InsightAttributes) => {
                    const category =
                      insight.insight_category && typeof insight.insight_category === 'object' && 'slug' in insight.insight_category
                        ? (insight.insight_category as InsightCategoryAttributes)
                        : null;
                    const categorySlug = category?.slug ?? '';
                    const href = insight.slug && categorySlug ? toHref(`/about/insights/${categorySlug}/${insight.slug}`, locale) : '#';
                    const summary = trimText(insight.excerpt || insight.description, 156);
                    return (
                      <li class="border-t border-gray-100 pt-4 first:border-t-0 first:pt-0">
                        {category?.name && (
                          <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-orange-500">
                            {category.name}
                          </p>
                        )}
                        <a href={href} class="mt-2 block text-sm font-bold leading-6 text-slate-900 transition-colors hover:text-orange-600">
                          {insight.title}
                        </a>
                        {summary && <p class="mt-2 text-sm leading-6 text-gray-600">{summary}</p>}
                      </li>
                    );
                  })}
                </ul>
              </div>
            )}
          </div>
        </section>
      )}

      {audience.length > 0 && (
        <section id="best-fit" class="mt-14 scroll-mt-24">
          <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
            <div>
              <h2 class="text-3xl font-black text-slate-950">
                {solution.audienceTitle || t(messages, 'solutions.audienceTitle')}
              </h2>
              <p class="mt-3 max-w-3xl text-base leading-7 text-gray-600">
                {t(messages, 'solutions.audienceDescription')}
              </p>
            </div>
          </div>

          <div class="mt-6 grid gap-4 md:grid-cols-3">
            {audience.map((item) => (
              <div class="border border-gray-200 bg-white p-6">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-orange-500">
                  {t(messages, 'solutions.audienceTitle')}
                </p>
                <h3 class="mt-3 text-xl font-bold text-slate-950">{item.name}</h3>
                <div class="mt-5 overflow-hidden border border-gray-100 bg-gray-50">
                  {item.image?.src ? (
                    item.image.width && item.image.height ? (
                      <Image
                        src={item.image.src}
                        alt={item.image.alt || item.name}
                        width={item.image.width}
                        height={item.image.height}
                        class="aspect-video w-full object-cover"
                        format="webp"
                        quality={90}
                      />
                    ) : (
                      <img
                        src={item.image.src}
                        alt={item.image.alt || item.name}
                        class="aspect-video w-full object-cover"
                      />
                    )
                  ) : (
                    <div class="flex aspect-video items-center justify-center p-4 text-center">
                      <div>
                        <p class="text-xs font-semibold text-slate-900">
                          {t(messages, 'solutions.audienceCardImagePlaceholderTitle')}
                        </p>
                        <p class="mt-1 text-xs leading-5 text-gray-500">
                          {t(messages, 'solutions.audienceCardImagePlaceholderDescription')}
                        </p>
                      </div>
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {problemPoints.length > 0 && (
        <section id="business-challenges" class="mt-14 scroll-mt-24">
          <h2 class="text-3xl font-black text-slate-950">
            {solution.problemPointsTitle || t(messages, 'solutions.problemPointsTitle')}
          </h2>
          <div class="mt-6 grid gap-4 md:grid-cols-2">
            {problemPoints.map((item) => (
              <div class="border border-gray-200 bg-white p-5">
                {item.title && <h3 class="text-lg font-bold text-slate-900">{item.title}</h3>}
                {item.description && <p class="mt-2 text-sm leading-6 text-gray-600">{item.description}</p>}
              </div>
            ))}
          </div>
        </section>
      )}

      {solution.overview && Array.isArray(solution.overview) && solution.overview.length > 0 && (
        <section id="solution-overview" class="mt-14 scroll-mt-24">
          <h2 class="text-3xl font-black text-slate-950">
            {solution.overviewTitle || t(messages, 'solutions.overviewTitle')}
          </h2>
          <BlocksRenderer blocks={solution.overview} class="mt-6" />
        </section>
      )}

      {expectedResults.length > 0 && (
        <section id="expected-results" class="mt-14 scroll-mt-24">
          <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
            <div>
              <h2 class="text-3xl font-black text-slate-950">
                {solution.expectedResultsTitle || t(messages, 'solutions.expectedResultsTitle')}
              </h2>
              <p class="mt-3 max-w-3xl text-base leading-7 text-gray-600">
                {t(messages, 'solutions.expectedResultsDescription')}
              </p>
            </div>
          </div>

          <div class="mt-6 grid gap-4 md:grid-cols-2">
            {expectedResults.map((item) => (
              <div class="border border-emerald-200 bg-emerald-50/60 p-6">
                {item.title && <h3 class="text-lg font-bold text-slate-950">{item.title}</h3>}
                {item.description && <p class="mt-2 text-sm leading-6 text-gray-700">{item.description}</p>}
              </div>
            ))}
          </div>
        </section>
      )}

      {processSteps.length > 0 && (
        <section id="recommended-process" class="mt-14 scroll-mt-24">
          <h2 class="text-3xl font-black text-slate-950">
            {solution.processTitle || t(messages, 'solutions.processTitle')}
          </h2>
          <div class="mt-6 grid gap-6 lg:grid-cols-2">
            {processSteps.map((step, index) => (
              <div class="border border-gray-200 bg-white p-6">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-orange-500">
                  {t(messages, 'solutions.stepLabel')} {index + 1}
                </p>
                {step.title && <h3 class="mt-2 text-xl font-bold text-slate-950">{step.title}</h3>}
                {step.description && step.description.length > 0 && (
                  <BlocksRenderer blocks={step.description} class="mt-4" />
                )}
              </div>
            ))}
          </div>
        </section>
      )}

      {recommendedProducts.length > 0 && (
        <section id="recommended-products" class="mt-16 scroll-mt-24">
          <h2 class="text-3xl font-black text-slate-950">
            {solution.recommendedProductsTitle || t(messages, 'solutions.recommendedProductsTitle')}
          </h2>
          <p class="mt-3 max-w-3xl text-base leading-7 text-gray-600">
            {t(messages, 'solutions.recommendedProductsDescription')}
          </p>
          <div class="mt-6 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
            {recommendedProducts.map((product: ProductAttributes) => (
              <ProductCard product={product} locale={locale} ctaLabel={t(messages, 'common.readMore')} />
            ))}
          </div>
        </section>
      )}

      {decisionFactors.length > 0 && (
        <section id="decision-factors" class="mt-16 scroll-mt-24">
          <h2 class="text-3xl font-black text-slate-950">
            {solution.decisionFactorsTitle || t(messages, 'solutions.decisionFactorsTitle')}
          </h2>
          <p class="mt-3 max-w-3xl text-base leading-7 text-gray-600">
            {t(messages, 'solutions.decisionFactorsDescription')}
          </p>
          <div class="mt-6 grid gap-4 md:grid-cols-2">
            {decisionFactors.map((item) => (
              <div class="border border-amber-200 bg-amber-50/60 p-6">
                {item.title && <h3 class="text-lg font-bold text-slate-950">{item.title}</h3>}
                {item.description && <p class="mt-2 text-sm leading-6 text-gray-700">{item.description}</p>}
              </div>
            ))}
          </div>
        </section>
      )}

      {relatedHelpCenters.length > 0 && (
        <section id="related-guides" class="mt-16 scroll-mt-24">
          <h2 class="text-3xl font-black text-slate-950">
            {solution.relatedHelpCentersTitle || t(messages, 'solutions.relatedGuidesTitle')}
          </h2>
          <p class="mt-3 max-w-3xl text-base leading-7 text-gray-600">
            {t(messages, 'solutions.relatedGuidesDescription')}
          </p>
          <div class="mt-6 grid gap-4 md:grid-cols-2">
            {relatedHelpCenters.map((article: HelpCenterAttributes) => {
              const categorySlug = article.help_category?.slug ?? '';
              const href = categorySlug && article.slug ? toHref(`/help/${categorySlug}/${article.slug}`, locale) : '#';
              return (
                <a href={href} class="border border-gray-200 bg-white p-5 transition-colors hover:border-orange-300">
                  <h3 class="text-lg font-bold text-slate-950">{article.title}</h3>
                  {article.description && <p class="mt-2 text-sm leading-6 text-gray-600">{article.description}</p>}
                </a>
              );
            })}
          </div>
        </section>
      )}

      {relatedInsights.length > 0 && (
        <section id="related-insights" class="mt-16 scroll-mt-24">
          <h2 class="text-3xl font-black text-slate-950">
            {solution.relatedInsightsTitle || t(messages, 'solutions.relatedInsightsTitle')}
          </h2>
          <p class="mt-3 max-w-3xl text-base leading-7 text-gray-600">
            {t(messages, 'solutions.relatedInsightsDescription')}
          </p>
          <div class="mt-6 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
            {relatedInsights.map((insight: InsightAttributes) => {
              const category = insight.insight_category && typeof insight.insight_category === 'object' && 'slug' in insight.insight_category
                ? (insight.insight_category as InsightCategoryAttributes)
                : null;
              const categorySlug = category?.slug ?? '';
              const href = insight.slug && categorySlug ? toHref(`/about/insights/${categorySlug}/${insight.slug}`, locale) : '#';
              return <InsightCard insight={insight} locale={locale} href={href} />;
            })}
          </div>
        </section>
      )}

      <ArticleSampleCta locale={locale} messages={messages} />
    </article>
  </div>
</BaseLayout>
