---
/**
 * Top Brands 已合并到产品页，详情页永久跳转到产品页。
 */
import { type Locale, getLocale } from '@/i18n/config';
import { toHref } from '@/utils/navigationData';

export async function getStaticPaths() {
  return [];
}

const params = Astro.params as { locale?: string };
const locale: Locale = getLocale(params.locale);
return Astro.redirect(toHref('/products', locale), 301);
---
