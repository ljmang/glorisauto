---
/**
 * 文章目录组件
 * 显示 h2 和 h3 的两层结构，点击可快速跳转到对应章节
 */

import type { Messages } from '@/i18n';
import { t } from '@/i18n';

interface TOCItem {
  id: string;
  text: string;
  level: 2 | 3;
}

interface Props {
  items: TOCItem[];
  locale: string;
  messages: Messages;
}

const { items, locale, messages } = Astro.props;

// 如果没有目录项，不渲染
if (!items || items.length === 0) {
  return null;
}

// 分组：h2 及其下的 h3
const groupedItems: Array<{ h2: TOCItem; h3s: TOCItem[] }> = [];
let currentH2: TOCItem | null = null;
let currentGroup: { h2: TOCItem; h3s: TOCItem[] } | null = null;

for (const item of items) {
  if (item.level === 2) {
    // 如果之前有 h2，先保存它
    if (currentGroup) {
      groupedItems.push(currentGroup);
    }
    // 创建新的 h2 分组
    currentH2 = item;
    currentGroup = { h2: item, h3s: [] };
  } else if (item.level === 3 && currentGroup) {
    // 将 h3 添加到当前分组
    currentGroup.h3s.push(item);
  }
}

// 添加最后一个分组
if (currentGroup) {
  groupedItems.push(currentGroup);
}
---

{groupedItems.length > 0 && (
  <aside
    class="hidden lg:block lg:w-72 lg:sticky lg:top-28 lg:self-start lg:max-h-[calc(100vh-7rem)] lg:overflow-y-auto"
    data-toc-root
  >
    <nav
      class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm"
      aria-label={t(messages, 'insights.tableOfContents')}
      data-toc
    >
      <p class="mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-orange-500">
        In this article
      </p>
      <h2 class="mb-4 text-lg font-bold text-slate-950">
        {t(messages, 'insights.tableOfContents')}
      </h2>
      <ul class="space-y-2">
        {groupedItems.map((group) => (
          <li>
            <a
              href={`#${group.h2.id}`}
              data-toc-link
              data-target-id={group.h2.id}
              data-level="2"
              data-active="false"
              class="block scroll-smooth py-1 text-sm font-semibold leading-6 text-slate-800 transition-colors hover:text-orange-500"
            >
              {group.h2.text}
            </a>
            {group.h3s.length > 0 && (
              <ul class="mt-1 space-y-1 border-l border-slate-200 pl-3 text-xs">
                {group.h3s.map((h3) => (
                  <li>
                    <a
                      href={`#${h3.id}`}
                      data-toc-link
                      data-target-id={h3.id}
                      data-level="3"
                      data-active="false"
                      class="block scroll-smooth py-1 leading-5 text-slate-500 transition-colors hover:text-orange-500"
                    >
                      {h3.text}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>
  </aside>
)}

<script is:inline>
  (() => {
    const initTocHighlight = () => {
      const tocRoot = document.querySelector('[data-toc-root]');
      if (!(tocRoot instanceof HTMLElement) || tocRoot.dataset.tocInitialized === 'true') return;
      tocRoot.dataset.tocInitialized = 'true';

      const toc = tocRoot.querySelector('[data-toc]');
      if (!(toc instanceof HTMLElement)) return;

      const links = Array.from(toc.querySelectorAll('[data-toc-link]')).filter((node) =>
        node instanceof HTMLAnchorElement
      );
      if (links.length === 0) return;

      const headingTargets = links
        .map((link) => {
          const targetId = link.dataset.targetId ?? '';
          const element = targetId ? document.getElementById(targetId) : null;
          return element ? { id: targetId, element } : null;
        })
        .filter(Boolean);

      if (headingTargets.length === 0) return;

      const TOP_OFFSET = 160;

      const setActiveLink = (activeId) => {
        links.forEach((link) => {
          const isActive = link.dataset.targetId === activeId;
          link.dataset.active = isActive ? 'true' : 'false';
          if (isActive) {
            link.setAttribute('aria-current', 'true');
          } else {
            link.removeAttribute('aria-current');
          }
        });
      };

      const resolveActiveId = () => {
        const currentScroll = window.scrollY + TOP_OFFSET;
        let activeId = headingTargets[0]?.id ?? '';

        for (const target of headingTargets) {
          const targetTop = target.element.getBoundingClientRect().top + window.scrollY;
          if (targetTop <= currentScroll) {
            activeId = target.id;
          } else {
            break;
          }
        }

        return activeId;
      };

      let ticking = false;
      const updateActiveFromScroll = () => {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(() => {
          setActiveLink(resolveActiveId());
          ticking = false;
        });
      };

      toc.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const link = target.closest('[data-toc-link]');
        if (!(link instanceof HTMLAnchorElement)) return;
        const targetId = link.dataset.targetId ?? '';
        if (targetId) setActiveLink(targetId);
      });

      window.addEventListener('scroll', updateActiveFromScroll, { passive: true });
      window.addEventListener('resize', updateActiveFromScroll);
      window.addEventListener('hashchange', () => {
        const hashId = decodeURIComponent(window.location.hash.replace(/^#/, ''));
        if (hashId) {
          setActiveLink(hashId);
        } else {
          updateActiveFromScroll();
        }
      });

      const initialHashId = decodeURIComponent(window.location.hash.replace(/^#/, ''));
      setActiveLink(initialHashId || resolveActiveId());
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTocHighlight, { once: true });
    } else {
      initTocHighlight();
    }
  })();
</script>

<style>
  [data-toc-link] {
    position: relative;
    border-radius: 0.5rem;
    padding-left: 0.875rem;
    margin-left: -0.875rem;
  }

  [data-toc-link][data-active='true'] {
    color: rgb(249 115 22);
  }

  [data-toc-link][data-active='true']::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.3rem;
    bottom: 0.3rem;
    width: 3px;
    border-radius: 9999px;
    background: rgb(249 115 22);
  }
</style>
