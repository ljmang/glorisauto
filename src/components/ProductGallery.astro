---
/**
 * 产品多图切换：主图 + 缩略图，点击缩略图切换主图
 */
interface ImageItem {
  src: string;
  alt: string;
  width?: number;
  height?: number;
}

interface Props {
  images: ImageItem[];
  productName: string;
}

const { images, productName } = Astro.props;
const list = Array.isArray(images) && images.length > 0 ? images : [];
const first = list[0];
// Astro Image 需要静态 import 或 getImage，这里主图/缩略图用普通 img 以支持动态 URL
---

<div class="product-gallery">
  <div class="mb-4 aspect-square w-full overflow-hidden p-8">
    {first ? (
      <img
        id="product-gallery-main"
        src={first.src}
        alt={first.alt || productName}
        width={first.width ?? 600}
        height={first.height ?? 600}
        class="h-full w-full object-contain"
        loading="eager"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center text-gray-400">No image</div>
    )}
  </div>
  {list.length > 1 && (
    <div class="flex justify-center flex-wrap gap-2" role="tablist" aria-label="Product images">
      {list.map((img, i) => (
        <button
          type="button"
          data-product-thumb
          data-src={img.src}
          data-alt={img.alt || productName}
          class="h-16 w-16 shrink-0 overflow-hidden rounded border-2 transition-colors focus:outline-none focus:ring-2 focus:ring-orange-500"
          class:list={[
            i === 0 ? 'border-orange-500' : 'border-gray-200 hover:border-gray-300',
          ]}
          aria-selected={i === 0}
          aria-label={`View image ${i + 1}`}
        >
          <img src={img.src} alt="" class="h-full w-full object-cover" width="64" height="64" loading="lazy" />
        </button>
      ))}
    </div>
  )}
</div>

<script>
  document.querySelectorAll('[data-product-thumb]').forEach((btn, i) => {
    btn.addEventListener('click', () => {
      const main = document.getElementById('product-gallery-main') as HTMLImageElement | null;
      if (!main) return;
      const src = btn.getAttribute('data-src');
      const alt = btn.getAttribute('data-alt');
      if (src) main.src = src;
      if (alt != null) main.alt = alt;
      document.querySelectorAll('[data-product-thumb]').forEach((b, j) => {
        b.setAttribute('aria-selected', j === i ? 'true' : 'false');
        b.classList.toggle('border-orange-500', j === i);
        b.classList.toggle('border-gray-200', j !== i);
      });
    });
  });
</script>
