---
import { supportedLocales, localeDisplayConfig, isRtlLocale, type Locale } from '@/i18n/config';
import { fetchApi, api } from '@/utils/strapiApi';
import { toHref } from '@/utils/navigationData';

interface Props {
  currentLocale: Locale;
}

interface InsightLocalization {
  locale?: string;
  slug?: string;
  insight_category?: {
    slug?: string;
  } | null;
}

interface InsightLookupResult {
  slug?: string;
  localizations?: InsightLocalization[];
}

interface ProductLocalization {
  locale?: string;
  slug?: string;
  category?: {
    slug?: string;
  } | null;
}

interface ProductLookupResult {
  slug?: string;
  category?: {
    slug?: string;
  } | null;
  localizations?: ProductLocalization[];
}

const { currentLocale } = Astro.props;
const isRtl = isRtlLocale(currentLocale);

const currentPath = Astro.url.pathname.replace(`/${currentLocale}`, '') || '/';
const localeToStrapi: Record<Locale, string> = { en: 'en', 'zh-cn': 'zh-cn', 'ja': 'ja', ar: 'ar' };
const strapiToLocale: Record<string, Locale> = { en: 'en', 'zh-cn': 'zh-cn', 'ja': 'ja', ar: 'ar' };

const resolvedPathByLocale: Record<Locale, string> = {
  en: currentPath,
  'zh-cn': currentPath,
  'ja': currentPath,
  ar: currentPath,
};

const insightMatch = currentPath.match(/^\/about\/insights\/([^/]+)\/([^/]+)\/?$/);
if (insightMatch) {
  const [, categorySlug, articleSlug] = insightMatch;
  const strapiLocale = localeToStrapi[currentLocale];
  const res = await fetchApi<{ data?: InsightLookupResult[] }>(api.insights, {
    locale: strapiLocale,
    populate: { localizations: { populate: { insight_category: true } } },
    filters: {
      $and: [
        { slug: { $eq: articleSlug } },
        { insight_category: { slug: { $eq: categorySlug } } },
      ],
    },
    pagination: { pageSize: 1 },
  });

  const item = Array.isArray(res?.data) ? res.data[0] : undefined;
  const localizations = Array.isArray(item?.localizations) ? item.localizations : [];

  for (const loc of localizations) {
    const targetLocale = loc.locale ? strapiToLocale[loc.locale] : undefined;
    if (!targetLocale || !loc.slug || !loc.insight_category?.slug) continue;
    resolvedPathByLocale[targetLocale] = `/about/insights/${loc.insight_category.slug}/${loc.slug}`;
  }
}

const productMatch = currentPath.match(/^\/products\/([^/]+)\/([^/]+)\/?$/);
if (productMatch) {
  const [, categorySlug, productSlug] = productMatch;
  const strapiLocale = localeToStrapi[currentLocale];
  const res = await fetchApi<{ data?: ProductLookupResult[] }>(api.products, {
    locale: strapiLocale,
    populate: {
      category: true,
      localizations: {
        populate: {
          category: true,
        },
      },
    },
    filters: {
      $and: [
        { slug: { $eq: productSlug } },
        { category: { slug: { $eq: categorySlug } } },
      ],
    },
    pagination: { pageSize: 1 },
  });

  const item = Array.isArray(res?.data) ? res.data[0] : undefined;
  const localizations = Array.isArray(item?.localizations) ? item.localizations : [];

  if (item?.slug && item.category?.slug) {
    resolvedPathByLocale[currentLocale] = `/products/${item.category.slug}/${item.slug}`;
  }

  for (const loc of localizations) {
    const targetLocale = loc.locale ? strapiToLocale[loc.locale] : undefined;
    if (!targetLocale || !loc.slug || !loc.category?.slug) continue;
    resolvedPathByLocale[targetLocale] = `/products/${loc.category.slug}/${loc.slug}`;
  }
}
---

<div class="relative" id="lang-switcher-wrap">
  <details class="relative group/details">
    <summary
      class="list-none flex items-center gap-1.5 p-2 text-sm cursor-pointer hover:text-orange-500 transition-colors min-w-[7rem]"
      aria-haspopup="listbox"
      aria-expanded="false"
    >
      <span class="text-lg leading-none" aria-hidden="true">{localeDisplayConfig[currentLocale].flag}</span>
      <span class="text-sm font-medium text-gray-700">{localeDisplayConfig[currentLocale].label}</span>
      <svg class={`w-4 h-4 text-gray-500 ${isRtl ? 'mr-auto' : 'ml-auto'} shrink-0 transition-transform group-open/details:rotate-180`} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </summary>
    <ul
      class={`absolute ${isRtl ? 'left-0' : 'right-0'} top-full mt-1 py-1 w-full min-w-[7rem] bg-white border border-gray-200 rounded-lg shadow-lg z-50`}
      role="listbox"
    >
      {supportedLocales.map((locale) => (
        <li role="option" aria-selected={locale === currentLocale}>
          <a
            href={toHref(resolvedPathByLocale[locale], locale)}
            class={`flex items-center gap-2 px-3 py-2 text-sm no-underline transition-colors ${
              locale === currentLocale
                ? 'text-orange-600'
                : 'text-gray-700 hover:bg-gray-50'
            }`}
          >
            <span class="text-lg leading-none">{localeDisplayConfig[locale].flag}</span>
            <span>{localeDisplayConfig[locale].label}</span>
          </a>
        </li>
      ))}
    </ul>
  </details>
</div>

<script is:inline>
  document.addEventListener('click', function (e) {
    const wrap = document.getElementById('lang-switcher-wrap');
    const details = wrap && wrap.querySelector('details');
    if (!wrap || !details) return;
    if (!wrap.contains(e.target)) {
      details.removeAttribute('open');
    }
  });
</script>
