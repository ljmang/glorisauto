---
import type { Locale } from '@/i18n/config';
import type { SolutionAttributes } from '@/types/content';
import { parseImage } from '@/utils/strapiApi';
import { toHref } from '@/utils/navigationData';
import { Image } from 'astro:assets';

interface Props {
  solution: SolutionAttributes;
  locale: Locale;
  ctaLabel: string;
}

const { solution, locale, ctaLabel } = Astro.props;
const cover = parseImage(solution.cover);
const href = toHref(`/solutions/${solution.slug}`, locale);
const audience = Array.isArray(solution.targetAudience)
  ? solution.targetAudience.map((item) => item?.name?.trim()).filter(Boolean)
  : [];
---

<a href={href} class="group block overflow-hidden border border-gray-200 bg-white transition-colors hover:border-orange-300">
  <div class="aspect-[16/9] overflow-hidden bg-gray-100">
    {cover?.src && cover.width && cover.height ? (
      <Image
        src={cover.src}
        alt={cover.alt || solution.title}
        width={cover.width}
        height={cover.height}
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
        loading="lazy"
        format="webp"
        quality={90}
      />
    ) : cover?.src ? (
      <img
        src={cover.src}
        alt={cover.alt || solution.title}
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
        loading="lazy"
      />
    ) : (
      <div class="flex h-full items-center justify-center text-sm text-gray-400">{solution.title}</div>
    )}
  </div>

  <div class="flex flex-col gap-4 p-6">
    <div>
      <h3 class="text-2xl font-black text-slate-950 transition-colors group-hover:text-orange-600">
        {solution.heroTitle || solution.title}
      </h3>
      {solution.summary && <p class="mt-3 text-sm leading-6 text-gray-600">{solution.summary}</p>}
    </div>

    {audience.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {audience.slice(0, 4).map((label) => (
          <span class="border border-gray-300 px-3 py-1 text-xs font-semibold uppercase tracking-[0.12em] text-gray-600">
            {label}
          </span>
        ))}
      </div>
    )}

    <div class="text-sm font-semibold text-cyan-600 transition-colors group-hover:text-orange-600">
      {ctaLabel}
    </div>
  </div>
</a>
