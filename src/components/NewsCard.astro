---
/**
 * 新闻卡片组件
 * 用于展示 glorisNews 中的每一项
 * 样式：图片在上（2/3高度），深灰色文字区域在下（1/3高度）
 */

import type { NewsItem } from '@/types/blocks';
import { parseImage } from '@/utils/strapiApi';
import { toHref } from '@/utils/navigationData';
import { extractTextFromBlocks } from '@/utils/blocks';
import { Image } from 'astro:assets';

interface Props {
  news: NewsItem;
  locale: string;
}

const { news, locale } = Astro.props;

const coverImage = parseImage(news.cover);
const href = toHref(news.url, locale);
const excerpt = extractTextFromBlocks(news.content, 120);
const noCoverLabelByLocale: Record<string, string> = {
  en: 'No cover image',
  'zh-cn': '暂无封面图',
  ja: 'カバー画像なし',
  ar: 'لا توجد صورة غلاف',
};
const noContentLabelByLocale: Record<string, string> = {
  en: 'No content',
  'zh-cn': '暂无内容',
  ja: 'コンテンツなし',
  ar: 'لا يوجد محتوى',
};
const noCoverLabel = noCoverLabelByLocale[locale] || noCoverLabelByLocale.en;
const noContentLabel = noContentLabelByLocale[locale] || noContentLabelByLocale.en;
---

<a
  href={href}
  class="group block overflow-hidden bg-white transition-all duration-300 h-full flex flex-col"
>
  <!-- 封面图区域 - 占约 2/3 高度 -->
  {coverImage && coverImage.src ? (
    coverImage.width && coverImage.height ? (
      <div class="relative w-full flex-[2] min-h-[200px] overflow-hidden">
        <Image
          src={coverImage.src}
          alt={coverImage.alt || news.title}
          width={coverImage.width}
          height={coverImage.height}
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          format="webp"
          quality={85}
          loading="lazy"
        />
      </div>
    ) : (
      <div class="relative w-full flex-[2] min-h-[200px] overflow-hidden bg-gray-200 flex items-center justify-center">
        <img
          src={coverImage.src}
          alt={coverImage.alt || news.title}
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
        />
      </div>
    )
  ) : (
    <div class="relative w-full flex-[2] min-h-[200px] bg-gray-300 flex items-center justify-center">
      <span class="text-gray-500 text-sm">{noCoverLabel}</span>
    </div>
  )}
  
  <!-- 文字内容区域 - 深灰色背景，占约 1/3 高度 -->
  <div class="px-6 lg:px-10 py-5 flex-[1] flex flex-col justify-center">
    <h3 class="text-xl font-bold mb-2 group-hover:text-orange-500 transition-colors">
      {news.title}
    </h3>
    {excerpt ? (
      <p class="text-gray-700 leading-relaxed">
        {excerpt}
      </p>
    ) : (
      <p class="text-gray-700 italic">{noContentLabel}</p>
    )}
  </div>
</a>
