---
import { t, type Messages } from "@/i18n";
import { type Locale } from "@/i18n/config";
import type { NavItem } from "@/utils/navigationData";
import { toHref } from "@/utils/navigationData";
import type { SiteSeoAttributes } from "@/types/content";
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import Navigation from "@/components/Navigation.svelte";
import MobileNavigation from "@/components/MobileNavigation.svelte";
import SearchBox from "@/components/SearchBox.svelte";
import { generateSearchIndex } from "@/utils/searchIndex";
import { PhoneCall, Mail, Search, Gift } from "lucide-svelte";

interface Props {
  messages: Messages;
  locale: Locale;
  navData?: NavItem[];
  siteSeo?: SiteSeoAttributes | null;
}

const { messages, locale, navData = [], siteSeo = null } = Astro.props;
const currentPath = Astro.url.pathname;
const searchIndex = await generateSearchIndex(locale);

const contactPhone = siteSeo?.contactPhone?.trim() || '+86 18122288163';
const contactEmail = siteSeo?.contactEmail?.trim() || 'Sales@glorisauto.com';
const contactPhoneHref = `tel:${contactPhone.replace(/[^\d+]/g, '')}`;
const customerServiceHref = toHref('/support/customer-service', locale);
const freeSampleHref = `${customerServiceHref}/?type=free-sample`;
const freeSampleLabel = t(messages, 'home.freeSampleCta');
---

<header class="bg-white sticky top-0 z-40 shadow-sm">
  <!-- connect us: hidden on mobile, shown in mobile nav popup -->
  <div
    class="hidden md:flex container mx-auto px-4 gap-4 items-center justify-end text-sm relative"
  >
    <!-- phone -->
    <div class="flex items-center gap-2">
      <PhoneCall class="w-4 h-4" />
      <a
        href={contactPhoneHref}
        class="hover:text-orange-500 transition-colors">{contactPhone}</a
      >
    </div>
    <!-- email -->
    <div class="flex items-center gap-2">
      <Mail class="w-4 h-4" />
      <a
        href={`mailto:${contactEmail}`}
        class="hover:text-orange-500 transition-colors">{contactEmail}</a
      >
    </div>
    <!-- language switcher -->
    <div class="flex items-center gap-2">
      <LanguageSwitcher currentLocale={locale} />
    </div>
  </div>
  <!-- main navigation -->
  <nav class="container mx-auto px-4 flex items-center justify-between gap-4 relative">
    <!-- 左侧：logo + 桌面导航 -->
    <div class="flex items-center gap-4 min-w-0">
      <a href={`/${locale}`} class="shrink-0">
        <img
          src="https://assets.glorisauto.com/uploads/logo_89e1563b6e.webp"
          alt="GLORIS"
          class="h-12 object-contain mb-4 mt-2 md:mt-0"
        />
      </a>
      <Navigation client:load locale={locale} currentPath={currentPath} navData={navData} />
    </div>
    <!-- 右侧：窄屏搜索图标 + 桌面搜索框 + CTA + 汉堡 -->
    <div class="flex items-center gap-1 shrink-0 justify-end">
      <a
        href={`/${locale}/search`}
        class="xl:hidden p-2 text-gray-700 hover:text-orange-500 transition-colors"
        aria-label="Search"
      >
        <Search class="w-6 h-6" />
      </a>
      <div class="hidden xl:block">
        <SearchBox
          client:load
          searchIndex={searchIndex}
          locale={locale}
          messages={messages}
        />
      </div>
      <a
        href={freeSampleHref}
        class="hidden xl:inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-full bg-orange-500 px-4 py-2 text-sm font-bold text-white shadow-sm transition-colors hover:bg-orange-600 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2 lg:px-5"
      >
        <Gift class="h-4 w-4 shrink-0" />
        {freeSampleLabel}
      </a>
      <MobileNavigation
        client:load
        currentPath={currentPath}
        locale={locale}
        messages={messages}
        navData={navData}
        contactPhone={contactPhone}
        contactEmail={contactEmail}
      />
    </div>
  </nav>
</header>
