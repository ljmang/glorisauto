---
import { t, type Messages } from "@/i18n";
import { type Locale } from "@/i18n/config";
import { toHref, type NavItem } from "@/utils/navigationData";
import type { SiteSeoAttributes } from "@/types/content";
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import Navigation from "@/components/Navigation.svelte";
import MobileNavigation from "@/components/MobileNavigation.svelte";
import SearchBox from "@/components/SearchBox.svelte";
import { generateSearchIndex } from "@/utils/searchIndex";
import { getSiteContactInfo } from "@/utils/siteContact";
import { PhoneCall, Mail, Search } from "lucide-svelte";

interface Props {
  messages: Messages;
  locale: Locale;
  navData?: NavItem[];
  siteSeo?: SiteSeoAttributes | null;
}

const { messages, locale, navData = [], siteSeo = null } = Astro.props;
const currentPath = Astro.url.pathname;
const searchIndex = await generateSearchIndex(locale);

const siteContact = getSiteContactInfo(siteSeo);
const homeHref = toHref('/', locale);
const searchHref = toHref('/search', locale);
const dealerHref = toHref('/about/dealer', locale);
const dealerCtaLabel = t(messages, 'dealer.headerCta');
---

<header data-site-header class="bg-white sticky top-0 z-40 shadow-sm">
  <!-- connect us: hidden on mobile, shown in mobile nav popup -->
  <div
    class="hidden md:flex container mx-auto px-4 gap-4 items-center justify-end py-1 text-sm relative"
  >
    <!-- phone -->
    <div class="flex items-center gap-2">
      <PhoneCall class="w-4 h-4" />
      <a
        href={siteContact.phoneHref}
        class="hover:text-orange-500 transition-colors">{siteContact.phone}</a
      >
    </div>
    <!-- email -->
    <div class="flex items-center gap-2">
      <Mail class="w-4 h-4" />
      <a
        href={`mailto:${siteContact.email}`}
        class="hover:text-orange-500 transition-colors">{siteContact.email}</a
      >
    </div>
    <!-- language switcher -->
    <div class="flex items-center gap-2">
      <LanguageSwitcher currentLocale={locale} />
    </div>
  </div>
  <!-- main navigation -->
  <nav class="container mx-auto px-4 py-2 flex items-center justify-between gap-4 relative">
    <!-- 左侧：logo + 桌面导航 -->
    <div class="flex items-center gap-4 min-w-0">
      <a href={homeHref} class="shrink-0">
        <img
          src="https://assets.glorisauto.com/uploads/logo_89e1563b6e.webp"
          alt="GLORIS"
          class="h-10 md:h-11 object-contain mb-4 mt-2 md:mt-0"
        />
      </a>
      <Navigation client:load locale={locale} currentPath={currentPath} navData={navData} />
    </div>
    <!-- 右侧：窄屏搜索图标 + 桌面 CTA + 搜索框 + 汉堡 -->
    <div class="flex items-center gap-1 shrink-0 justify-end">
      <a
        href={searchHref}
        class="xl:hidden p-2 text-gray-700 hover:text-orange-500 transition-colors"
        aria-label="Search"
      >
        <Search class="w-6 h-6" />
      </a>
      <a
        href={dealerHref}
        class="hidden xl:inline-flex items-center justify-center gap-2.5 whitespace-nowrap rounded-full bg-orange-500 px-6 h-12 text-base font-bold text-white shadow-sm transition-colors hover:bg-orange-600 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2"
      >
        <img
          src="/images/icon-distributor.svg"
          alt=""
          aria-hidden="true"
          class="h-5 w-5 shrink-0 object-contain"
        />
        {dealerCtaLabel}
      </a>
      <div class="hidden xl:block">
        <SearchBox
          client:load
          searchIndex={searchIndex}
          locale={locale}
          messages={messages}
        />
      </div>
      <MobileNavigation
        client:load
        currentPath={currentPath}
        locale={locale}
        messages={messages}
        navData={navData}
        contactPhone={siteContact.phone}
        contactEmail={siteContact.email}
      />
    </div>
  </nav>
</header>
