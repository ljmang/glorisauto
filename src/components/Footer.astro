---
import { type Messages, t } from '@/i18n';
import { type Locale } from '@/i18n/config';
import { Facebook, Youtube } from '@/components/icons';
import { toHref, type NavItem, type NavLink } from '@/utils/navigationData';

interface Props {
  messages: Messages;
  locale: Locale;
  navData?: NavItem[];
}

type FooterSection = {
  title: string;
  links: NavLink[];
};

const { messages, locale, navData = [] } = Astro.props;
const currentYear = new Date().getFullYear().toString();
const homeHref = toHref('/', locale);
const privacyHref = toHref('/privacy-policy', locale);
const cookiePreferencesHref = toHref('/cookie-preferences', locale);

function linksFromNavItem(item: NavItem): NavLink[] {
  if (Array.isArray(item.columns) && item.columns.length > 0) {
    const links = item.columns
      .map((column) => ({
        label: column.title,
        href: column.href || column.items[0]?.href || item.href,
      }))
      .filter((link): link is NavLink => Boolean(link.label && link.href));

    if (links.length > 0) return links;
  }

  if (item.href) {
    return [{ label: item.label, href: item.href }];
  }

  return [];
}

const fallbackSections: FooterSection[] = [
  {
    title: t(messages, 'footer.products.title'),
    links: [
      { label: t(messages, 'footer.products.abrasivePaper'), href: toHref('/products/abrasive-paper', locale) },
      { label: t(messages, 'footer.products.films'), href: toHref('/products/films', locale) },
      { label: t(messages, 'footer.products.compoundsPolishes'), href: toHref('/products/compounds-polishes', locale) },
      { label: t(messages, 'footer.products.automotiveWindowFilm'), href: toHref('/products/automotive-window-film', locale) },
      { label: t(messages, 'footer.products.paintProtectionFilms'), href: toHref('/products/paint-protection-films', locale) },
    ],
  },
  {
    title: t(messages, 'footer.support.title'),
    links: [
      { label: t(messages, 'footer.support.download'), href: toHref('/support/download', locale) },
      { label: t(messages, 'footer.support.helpCenter'), href: toHref('/help', locale) },
      { label: t(messages, 'footer.support.training'), href: toHref('/support/training', locale) },
    ],
  },
  {
    title: t(messages, 'footer.about.title'),
    links: [
      { label: t(messages, 'footer.about.brandStory'), href: toHref('/about/brand-story', locale) },
      { label: t(messages, 'footer.about.productionBase'), href: toHref('/about/insights/news/our-factory', locale) },
      { label: t(messages, 'footer.about.becomeDealer'), href: toHref('/about/dealer', locale) },
      { label: t(messages, 'footer.about.contactUs'), href: toHref('/support/customer-service', locale) },
      { label: t(messages, 'footer.about.insights'), href: toHref('/about/insights', locale) },
    ],
  },
];

const footerSections: FooterSection[] = navData.length > 0
  ? navData
      .map((item) => ({
        title: item.label,
        links: linksFromNavItem(item),
      }))
      .filter((section) => section.links.length > 0)
  : fallbackSections;
---

<footer class="bg-black text-white mt-auto">
  <div class="container mx-auto px-4 py-12">
    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <!-- Logo Column -->
      <div class="col-span-1">
        <a href={homeHref} class="text-2xl font-bold text-white no-underline hover:text-orange-500 transition-colors">
          <img src="https://assets.glorisauto.com/uploads/logo_w_a030442c50.webp" alt="GLORIS" class="h-12 object-contain">
        </a>
      </div>

      {footerSections.map((section) => (
        <div>
          <h3 class="text-white font-semibold mb-4 uppercase">
            {section.title}
          </h3>
          <ul class="space-y-2 list-none p-0 m-0">
            {section.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-gray-300 no-underline hover:text-orange-500 transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Social Media & Bottom Bar -->
    <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <!-- Social Media Icons -->
      <div class="flex items-center gap-4">
        <a
          href="https://www.facebook.com/share/1B1sp6u6gY/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-300 hover:text-orange-500 transition-colors"
          aria-label="Facebook"
        >
          <Facebook class="w-6 h-6" />
        </a>
        <a
          href="https://www.youtube.com/@haoyuanwang-v7f"
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-300 hover:text-orange-500 transition-colors"
          aria-label="YouTube"
        >
          <Youtube class="w-6 h-6" />
        </a>
      </div>

      <!-- Copyright & Links -->
      <div class="flex flex-col md:flex-row items-center gap-4 text-gray-300">
        <span>{t(messages, 'footer.copyright', { year: currentYear })}</span>
        <div class="flex gap-4">
          <a
            href={privacyHref}
            class="text-gray-300 no-underline hover:text-orange-500 transition-colors"
          >
            {t(messages, 'footer.privacy')}
          </a>
          <a
            href={cookiePreferencesHref}
            class="text-gray-300 no-underline hover:text-orange-500 transition-colors"
          >
            {t(messages, 'footer.cookiePreferences')}
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
