---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { type Messages, type Locale } from '@/i18n';
import { localeLanguageTag, localeOgTag, isRtlLocale, defaultLocale } from '@/i18n/config';
import type { SeoPageAttributes, SiteSeoAttributes } from '@/types/content';
import type { StrapiResponse, StrapiSeo } from '@/types';
import type { BreadcrumbMetaItem, JsonLdNode, SeoPageType } from '@/utils/seo';
import { resolveSeoMeta } from '@/utils/seo';
import { fetchApiWithLocaleFallback, api } from '@/utils/strapiApi';
import { transformNavigations } from '@/utils/navigationData';
import { fetchSeoPage, fetchSiteSeo } from '@/utils/siteConfig';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: unknown;
  messages: Messages;
  locale: Locale;
  seo?: StrapiSeo | null;
  pageType?: SeoPageType;
  breadcrumbs?: BreadcrumbMetaItem[];
  jsonLd?: JsonLdNode | JsonLdNode[] | null;
  publishedTime?: string;
  modifiedTime?: string;
  authorName?: string;
  siteSeo?: SiteSeoAttributes | null;
}

const {
  title,
  description,
  image,
  messages,
  locale,
  seo = null,
  pageType,
  breadcrumbs,
  jsonLd = null,
  publishedTime,
  modifiedTime,
  authorName,
  siteSeo: providedSiteSeo = undefined,
} = Astro.props;

type NavItem = ReturnType<typeof transformNavigations>;

function stripLocalePrefix(path: string): string {
  const normalized = path.replace(/^\/(en|zh-cn|ja|ar)(?=\/|$)/i, '');
  const withoutTrailing = normalized.replace(/\/+$/, '');
  return withoutTrailing || '/';
}

function navItemKey(item: { href: string }): string {
  return stripLocalePrefix(item.href || '/');
}

function hasDropdown(navData: NavItem): boolean {
  return navData.some((item) => Array.isArray(item.columns) && item.columns.length > 0);
}

function mergeNavWithFallback(localized: NavItem, fallback: NavItem): NavItem {
  const fallbackByKey = new Map(fallback.map((item) => [navItemKey(item), item]));
  const mergedLocalized = localized.map((item) => {
    if (Array.isArray(item.columns) && item.columns.length > 0) return item;
    const fallbackItem = fallbackByKey.get(navItemKey(item));
    if (fallbackItem?.columns && fallbackItem.columns.length > 0) {
      return { ...item, columns: fallbackItem.columns };
    }
    return item;
  });

  const existingKeys = new Set(mergedLocalized.map((item) => navItemKey(item)));
  const fallbackOnly = fallback.filter((item) => !existingKeys.has(navItemKey(item)));
  return [...mergedLocalized, ...fallbackOnly];
}

async function getNavData(currentLocale: Locale): Promise<NavItem> {
  const navigationQuery = {
    populate: {
      items: {
        populate: {
          children: {
            populate: {
              children: true,
            },
          },
        },
      },
    },
  } as const;

  const localizedRes = await fetchApiWithLocaleFallback<{ data?: unknown }>(api.navigation, {
    locale: currentLocale,
    ...navigationQuery,
  });
  const localizedNav = transformNavigations(localizedRes, currentLocale);

  if (currentLocale === defaultLocale || hasDropdown(localizedNav)) {
    return localizedNav;
  }

  const fallbackRes = await fetchApiWithLocaleFallback<{ data?: unknown }>(api.navigation, {
    locale: defaultLocale,
    ...navigationQuery,
  });
  const fallbackNav = transformNavigations(fallbackRes, currentLocale);
  if (!hasDropdown(fallbackNav)) return localizedNav;
  return mergeNavWithFallback(localizedNav, fallbackNav);
}

async function getSiteSeo(currentLocale: Locale): Promise<SiteSeoAttributes | null> {
  try {
    return await fetchSiteSeo(currentLocale);
  } catch (error) {
    console.error('[BaseLayout] failed to load site SEO, falling back to page defaults:', error);
    return null;
  }
}

async function getSeoPage(currentLocale: Locale, pathname: string): Promise<SeoPageAttributes | null> {
  try {
    return await fetchSeoPage(currentLocale, pathname);
  } catch (error) {
    console.error('[BaseLayout] failed to load seo page, falling back to defaults:', error);
    return null;
  }
}

const [navData, siteSeo, seoPage] = await Promise.all([
  getNavData(locale),
  providedSiteSeo === undefined ? getSiteSeo(locale) : Promise.resolve(providedSiteSeo),
  getSeoPage(locale, Astro.url.pathname),
]);

const resolvedSeo = resolveSeoMeta({
  title,
  description,
  image,
  seo,
  seoPage,
  siteSeo,
  locale,
  pathname: Astro.url.pathname,
  currentOrigin: Astro.url.origin,
  pageType,
  breadcrumbs,
  extraJsonLd: jsonLd,
  publishedTime,
  modifiedTime,
  authorName,
});

const htmlLang = localeLanguageTag[locale];
const ogLocale = localeOgTag[locale];
const htmlDir = isRtlLocale(locale) ? 'rtl' : 'ltr';
const siteName = siteSeo?.siteName?.trim() || siteSeo?.companyName?.trim() || 'Gloris Auto';
---

<!doctype html>
<html lang={htmlLang} dir={htmlDir} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content={resolvedSeo.viewport} />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content={resolvedSeo.robots} />
    {resolvedSeo.description && <meta name="description" content={resolvedSeo.description} />}
    {resolvedSeo.keywords && <meta name="keywords" content={resolvedSeo.keywords} />}
    {siteSeo?.googleVerification && <meta name="google-site-verification" content={siteSeo.googleVerification} />}
    {siteSeo?.bingVerification && <meta name="msvalidate.01" content={siteSeo.bingVerification} />}
    <link rel="canonical" href={resolvedSeo.canonicalUrl} />
    {resolvedSeo.alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.hrefLang} href={alternate.href} />
    ))}
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" sizes="any" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/favicon-48x48.png" />
    <title>{resolvedSeo.title}</title>

    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:type" content={resolvedSeo.ogType} />
    <meta property="og:title" content={resolvedSeo.ogTitle} />
    {resolvedSeo.ogDescription && <meta property="og:description" content={resolvedSeo.ogDescription} />}
    <meta property="og:url" content={resolvedSeo.canonicalUrl} />
    {resolvedSeo.ogImage && <meta property="og:image" content={resolvedSeo.ogImage} />}

    <meta name="twitter:card" content={resolvedSeo.twitterCard} />
    <meta name="twitter:title" content={resolvedSeo.twitterTitle} />
    {resolvedSeo.twitterDescription && <meta name="twitter:description" content={resolvedSeo.twitterDescription} />}
    {resolvedSeo.twitterImage && <meta name="twitter:image" content={resolvedSeo.twitterImage} />}

    {pageType === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {pageType === 'article' && (modifiedTime || publishedTime) && (
      <meta property="article:modified_time" content={modifiedTime || publishedTime} />
    )}

    <!-- Google Tag Manager -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-MBDTPXL3');
    </script>
    <!-- End Google Tag Manager -->

    {resolvedSeo.jsonLd.map((schema, index) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} data-schema={String(index)} />
    ))}
  </head>
  <body class="min-h-screen flex flex-col bg-gray-50 font-sans font-normal tracking-tight antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-MBDTPXL3"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->
    <Header messages={messages} locale={locale} navData={navData} siteSeo={siteSeo} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer messages={messages} locale={locale} navData={navData} />
    <script is:inline>
      var Tawk_API = Tawk_API || {}, Tawk_LoadStart = new Date();
      (function () {
        var s1 = document.createElement('script'), s0 = document.getElementsByTagName('script')[0];
        s1.async = true;
        s1.src = 'https://embed.tawk.to/69d745e76839171c36f07831/default';
        s1.charset = 'UTF-8';
        s1.setAttribute('crossorigin', '*');
        s0.parentNode.insertBefore(s1, s0);
      })();
    </script>
  </body>
</html>
